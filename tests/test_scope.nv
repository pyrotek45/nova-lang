module test_scope

import super.std.core

// Block scoping
let x = 10
if true {
    let y = 20
    assert(x == 10, "outer visible in block")
    assert(y == 20, "inner defined in block")
}

// Modifying outer from inner scope
let a = 1
if true {
    a = 2
}
assert(a == 2, "outer modified from block")

// Nested blocks
let v = 0
if true {
    if true {
        if true {
            v = 42
        }
    }
}
assert(v == 42, "deeply nested block modifies outer")

// Loop creates new scope each iteration
let values = []: Int
for let i = 0; i < 5; i += 1 {
    let local = i * 10
    values.push(local)
}
assert(values.len() == 5, "loop scope values length")
assert(values[0] == 0, "loop scope iteration 0")
assert(values[4] == 40, "loop scope iteration 4")

// Function creates its own scope
let outer = 100
fn get_outer() -> Int {
    return outer
}
assert(get_outer() == 100, "function sees outer scope")

// Function parameters are local
fn add_to(x: Int) -> Int {
    let local = x + 10
    return local
}
assert(add_to(5) == 15, "function local scope")

// While loop scope
let w = 0
let n = 3
while n > 0 {
    let inner = n
    w += inner
    n -= 1
}
assert(w == 6, "while loop scope accumulation")

// For-in scope
let for_sum = 0
for item in [10, 20, 30] {
    let doubled = item * 2
    for_sum += doubled
}
assert(for_sum == 120, "for-in scope")

// Closure captures outer scope
let captured = 42
let get_captured = || captured
assert(get_captured() == 42, "closure captures outer")

// Closure over mutable state
let state = Box(0)
let mutate = || {
    state.value += 1
}
mutate()
mutate()
assert(state.value == 2, "closure mutates captured")

// ---- Shadowing in nested function ----
let shadow = 10
fn inner_shadow() -> Int {
    let shadow = 99
    return shadow
}
assert(inner_shadow() == 99, "function local shadows outer")
assert(shadow == 10, "outer unaffected by fn shadow")

// ---- Block scope: variable defined inside block not needed after ----
let block_result = 0
if true {
    let tmp = 42
    block_result = tmp * 2
}
assert(block_result == 84, "block scope: tmp used inside, result outside")

// ---- Multiple loops each with their own scope ----
let loop1_sum = 0
for let i = 0; i < 3; i += 1 {
    let v1 = i + 10
    loop1_sum += v1
}
let loop2_sum = 0
for let j = 0; j < 3; j += 1 {
    let v2 = j * 100
    loop2_sum += v2
}
assert(loop1_sum == 33, "loop1 scope: (10+11+12)=33")
assert(loop2_sum == 300, "loop2 scope: (0+100+200)=300")

// ---- Closure captures correct variable (not aliased) ----
let val_a = Box(1)
let val_b = Box(2)
let get_a = || val_a.value
let get_b = || val_b.value
val_a.value = 100
val_b.value = 200
assert(get_a() == 100, "closure captures val_a by ref")
assert(get_b() == 200, "closure captures val_b by ref")

// ---- Global scope: function sees top-level ----
let global_const = 42
fn read_global() -> Int {
    return global_const
}
assert(read_global() == 42, "function reads global_const")

println("PASS: test_scope")
