module test_signal

import super.std.signal
import super.std.core

// ── Signal(T) typed ──────────────────────────────────────────

// Int payload
let onDamage = Signal::new() @[T: Int]
let hp = Box(100)
onDamage.connect(|dmg: Int| { hp.value -= dmg })
onDamage.emit(25)
assert(hp.value == 75, "Signal(Int) emit reduces hp")
onDamage.emit(10)
assert(hp.value == 65, "Signal(Int) second emit")
println("PASS: Signal(Int)")

// String payload
let onChat = Signal::new() @[T: String]
let msgs = Box("")
onChat.connect(|msg: String| { msgs.value = msgs.value + msg + ";" })
onChat.emit("hello")
onChat.emit("world")
assert(msgs.value == "hello;world;", "Signal(String) accumulates")
println("PASS: Signal(String)")

// Multiple listeners
let onScore = Signal::new() @[T: Int]
let a = Box(0)
let b = Box(0)
onScore.connect(|v: Int| { a.value += v })
onScore.connect(|v: Int| { b.value += v * 2 })
onScore.emit(5)
assert(a.value == 5, "multi listener a")
assert(b.value == 10, "multi listener b")
println("PASS: multiple listeners")

// count + clear
assert(onScore.count() == 2, "count before clear")
onScore.clear()
assert(onScore.count() == 0, "count after clear")
onScore.emit(100)
assert(a.value == 5, "cleared signal does not fire")
println("PASS: count and clear")

// ── VoidSignal ───────────────────────────────────────────────

let onReady = VoidSignal::new()
let called = Box(0)
onReady.connect(|| { called.value += 1 })
onReady.connect(|| { called.value += 10 })
onReady.emit()
assert(called.value == 11, "VoidSignal fires both")
onReady.emit()
assert(called.value == 22, "VoidSignal fires again")
println("PASS: VoidSignal")

// ── SignalBus ────────────────────────────────────────────────

let bus = SignalBus::new()

// register + connect + emit
let gameOver = Box(false)
let levelUp  = Box(0)

bus.register("game_over")
bus.connect("game_over", || { gameOver.value = true })

bus.connect("level_up", || { levelUp.value += 1 })  // auto-registers

bus.emit("game_over")
assert(gameOver.value, "bus game_over fired")

bus.emit("level_up")
bus.emit("level_up")
assert(levelUp.value == 2, "bus level_up fired twice")

// has
assert(bus.has("game_over"), "bus has game_over")
assert(bus.has("level_up"), "bus has level_up")
assert(!bus.has("nope"), "bus !has nope")

// signalCount
assert(bus.signalCount("game_over") == 1, "bus count game_over")
assert(bus.signalCount("level_up") == 1, "bus count level_up")
assert(bus.signalCount("nope") == 0, "bus count nonexistent")

// clear one signal
bus.clear("game_over")
assert(bus.signalCount("game_over") == 0, "bus clear game_over")

// clearAll
bus.clearAll()
assert(!bus.has("game_over"), "bus clearAll removed game_over")
assert(!bus.has("level_up"), "bus clearAll removed level_up")

// emit nonexistent signal (should not crash)
bus.emit("nonexistent")

println("PASS: SignalBus")

// ── Signal(Float) ────────────────────────────────────────────

let onHealth = Signal::new() @[T: Float]
let lastHp = Box(0.0)
onHealth.connect(|hp: Float| { lastHp.value = hp })
onHealth.emit(75.5)
assert(lastHp.value == 75.5, "Signal(Float) emit")
onHealth.emit(0.0)
assert(lastHp.value == 0.0, "Signal(Float) zero")
println("PASS: Signal(Float)")

// ── Signal(Bool) — used by Toggle widget ─────────────────────

let onToggle = Signal::new() @[T: Bool]
let togState = Box(false)
onToggle.connect(|v: Bool| { togState.value = v })
onToggle.emit(true)
assert(togState.value == true, "Signal(Bool) true")
onToggle.emit(false)
assert(togState.value == false, "Signal(Bool) false")
println("PASS: Signal(Bool)")

// ── Signal with struct payload ───────────────────────────────

struct DamageEvent { amount: Int, source: String }

let onDmg = Signal::new() @[T: DamageEvent]
let lastSource = Box("")
let totalDmg = Box(0)
onDmg.connect(fn(evt: DamageEvent) {
    lastSource.value = evt.source
    totalDmg.value += evt.amount
})
onDmg.emit(DamageEvent { amount: 30, source: "fire" })
onDmg.emit(DamageEvent { amount: 15, source: "ice" })
assert(totalDmg.value == 45, "Signal(struct) accumulates")
assert(lastSource.value == "ice", "Signal(struct) last source")
println("PASS: Signal(struct)")

// ── Disconnect pattern: clear + reconnect ────────────────────

let sig = Signal::new() @[T: Int]
let acc = Box(0)
sig.connect(|v: Int| { acc.value += v })
sig.emit(10)
assert(acc.value == 10, "pre-clear fires")
sig.clear()
sig.emit(10)
assert(acc.value == 10, "post-clear does not fire")
sig.connect(|v: Int| { acc.value += v * 2 })
sig.emit(5)
assert(acc.value == 20, "reconnected listener fires")
println("PASS: disconnect/reconnect")

// ── VoidSignal count and clear ───────────────────────────────

let vs = VoidSignal::new()
assert(vs.count() == 0, "VoidSignal empty count")
vs.connect(|| {})
vs.connect(|| {})
vs.connect(|| {})
assert(vs.count() == 3, "VoidSignal 3 listeners")
vs.clear()
assert(vs.count() == 0, "VoidSignal cleared")
println("PASS: VoidSignal count/clear")

// ── SignalBus: multiple listeners on same name ───────────────

let bus2 = SignalBus::new()
let x = Box(0)
bus2.connect("tick", || { x.value += 1 })
bus2.connect("tick", || { x.value += 10 })
bus2.emit("tick")
assert(x.value == 11, "bus multi-listener same name")
assert(bus2.signalCount("tick") == 2, "bus signalCount 2")
println("PASS: SignalBus multi-listener")

println("ALL SIGNAL TESTS PASSED")
