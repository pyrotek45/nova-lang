module test_lists

import super.std.list

// List construction
let empty = []: Int
assert(empty.len() == 0, "empty list")

let nums = [1, 2, 3]
assert(nums.len() == 3, "list length")

// List access
assert(nums[0] == 1, "list index 0")
assert(nums[1] == 2, "list index 1")
assert(nums[2] == 3, "list index 2")

// List assignment
let arr = [10, 20, 30]
arr[1] = 99
assert(arr[1] == 99, "list index assignment")

// List push
let list = []: Int
list.push(1)
list.push(2)
list.push(3)
assert(list.len() == 3, "list push length")
assert(list[0] == 1, "pushed element 0")
assert(list[2] == 3, "pushed element 2")

// List pop
let poppable = [1, 2, 3]
let popped = poppable.pop()
assert(popped.isSome(), "pop returns Some")
assert(popped.unwrap() == 3, "pop returns last element")
assert(poppable.len() == 2, "list shrinks after pop")

// Pop from empty
let emptylist = []: Int
let nothing = emptylist.pop()
assert(nothing.isSome() == false, "pop empty returns None")

// List of strings
let names = ["alice", "bob", "charlie"]
assert(names[0] == "alice", "string list access")
assert(names.len() == 3, "string list length")

// List of bools
let bools = [true, false, true]
assert(bools[0], "bool list true")
assert(!bools[1], "bool list false")

// Nested lists
let matrix = [[1, 2], [3, 4], [5, 6]]
assert(matrix.len() == 3, "nested list outer length")
assert(matrix[0][0] == 1, "nested access [0][0]")
assert(matrix[1][1] == 4, "nested access [1][1]")
assert(matrix[2][0] == 5, "nested access [2][0]")

// List fill
let filled = []: Int.fill(7, 5)
assert(filled.len() == 5, "fill length")
assert(filled[0] == 7, "fill value 0")
assert(filled[4] == 7, "fill value 4")

// List map
let doubled = [1, 2, 3].map(|x: Int| x * 2)
assert(doubled[0] == 2, "map doubled 0")
assert(doubled[1] == 4, "map doubled 1")
assert(doubled[2] == 6, "map doubled 2")

// List filter
let evens = [1, 2, 3, 4, 5, 6].filter(|x: Int| x % 2 == 0)
assert(evens.len() == 3, "filter length")
assert(evens[0] == 2, "filter 0")
assert(evens[1] == 4, "filter 1")
assert(evens[2] == 6, "filter 2")

// List remove
let removable = [1, 2, 3, 4]
removable.remove(1)
assert(removable.len() == 3, "remove shrinks list")
assert(removable[0] == 1, "remove keeps earlier")
assert(removable[1] == 3, "remove shifts later down")

// List contains
assert([1, 2, 3].contains(2), "contains existing")
assert(!([1, 2, 3].contains(5)), "not contains missing")

// List indexOf
assert([10, 20, 30].indexOf(20) == 1, "indexOf found")
assert([10, 20, 30].indexOf(99) == -1, "indexOf not found")

// List reverse
let rev = [1, 2, 3].reverse()
assert(rev[0] == 3, "reverse 0")
assert(rev[1] == 2, "reverse 1")
assert(rev[2] == 1, "reverse 2")

// List sum
assert([1, 2, 3, 4].sum() == 10, "int sum")
assert([1.0, 2.0, 3.0].sum() == 6.0, "float sum")

// List product
assert([1, 2, 3, 4].product() == 24, "product")

// List min/max
assert([3, 1, 4, 1, 5].min() == 1, "list min")
assert([3, 1, 4, 1, 5].max() == 5, "list max")

// List slice
let sliced = [10, 20, 30, 40, 50].slice(1, 4)
assert(sliced.len() == 3, "slice length")
assert(sliced[0] == 20, "slice 0")
assert(sliced[2] == 40, "slice 2")

// List unique
let uniq = [1, 2, 2, 3, 3, 3].unique()
assert(uniq.len() == 3, "unique length")

// List concat
let merged = [1, 2].concat([3, 4])
assert(merged.len() == 4, "concat length")
assert(merged[2] == 3, "concat element")

// List zip
let zipped = [1, 2, 3].zip(["a", "b", "c"])
assert(zipped.len() == 3, "zip length")

// List equality
assert([1, 2, 3] == [1, 2, 3], "list equality")
assert([1, 2, 3] != [1, 2, 4], "list inequality")

// List all / any
assert([true, true, true].all(), "all true")
assert(!([true, false, true].all()), "not all true")
assert([false, true, false].any(), "any true")
assert(!([false, false, false].any()), "none true")

println("PASS: test_lists")
