module test_std_integration2

import super.std.core
import super.std.signal
import super.std.entity
import super.std.vec2
import super.std.container
import super.std.color
import super.std.list
import super.std.hashmap
import super.std.functional

// ============================================================
// Standard Library Integration Tests — Part 2
//
// Exercises the NEW std modules together: signals, entities,
// containers, color, and their interactions with existing
// modules (Box, HashMap, List, Vec2, etc.).
// ============================================================

// ── 1. Signal + Box: mutable state via signal callbacks ──────
fn signal_box_state() {
    let hp = Box(100)
    let log = Box([]: String)

    let onDamage = Signal::new() @[T: Int]
    onDamage.connect(|dmg: Int| {
        hp.value -= dmg
        log.value.push("hit:" + Cast::string(dmg))
    })
    onDamage.connect(|dmg: Int| {
        if hp.value <= 0 {
            log.value.push("dead")
        }
    })

    onDamage.emit(30)
    assert(hp.value == 70, "1: hp after 30 dmg")
    assert(log.value.len() == 1, "1: one log entry")

    onDamage.emit(80)
    assert(hp.value == -10, "1: hp after 80 more")
    assert(log.value.len() == 3, "1: hit + dead logged")
    assert(log.value[2] == "dead", "1: dead message")
}
signal_box_state()

// ── 2. VoidSignal + counter ──────────────────────────────────
fn voidsignal_counter() {
    let count = Box(0)
    let sig = VoidSignal::new()
    sig.connect(|| { count.value += 1 })
    sig.connect(|| { count.value += 10 })

    for let i = 0; i < 5; i += 1 {
        sig.emit()
    }
    assert(count.value == 55, "2: 5*(1+10) = 55")
    assert(sig.count() == 2, "2: two listeners")

    sig.clear()
    sig.emit()
    assert(count.value == 55, "2: no change after clear")
    assert(sig.count() == 0, "2: zero listeners after clear")
}
voidsignal_counter()

// ── 3. SignalBus: named events ───────────────────────────────
fn signalbus_events() {
    let bus = SignalBus::new()
    let history = Box([]: String)

    bus.register("start")
    bus.register("pause")
    bus.register("stop")

    bus.connect("start", || { history.value.push("started") })
    bus.connect("pause", || { history.value.push("paused") })
    bus.connect("stop",  || { history.value.push("stopped") })

    assert(bus.has("start"), "3: has start")
    assert(!bus.has("restart"), "3: no restart")

    bus.emit("start")
    bus.emit("pause")
    bus.emit("stop")

    assert(history.value.len() == 3, "3: three events")
    assert(history.value[0] == "started", "3: first event")
    assert(history.value[2] == "stopped", "3: last event")

    bus.clear("start")
    bus.emit("start")
    assert(history.value.len() == 3, "3: start cleared, no new event")
}
signalbus_events()

// ── 4. Entity + Signal: world callbacks ──────────────────────
fn entity_world_signals() {
    let spawnLog = Box([]: Int)
    let killLog  = Box([]: Int)
    let clearCount = Box(0)

    let world = EntityWorld::new() @[T: Int]
    world.onSpawn.connect(|id: Int| { spawnLog.value.push(id) })
    world.onKill.connect(|id: Int| { killLog.value.push(id) })
    world.onClear.connect(|| { clearCount.value += 1 })

    let e1 = world.spawn(10.0, 20.0, "a", 100)
    let e2 = world.spawn(30.0, 40.0, "b", 200)
    let e3 = world.spawn(50.0, 60.0, "a", 300)

    assert(spawnLog.value.len() == 3, "4: 3 spawns logged")
    assert(world.count() == 3, "4: 3 entities")
    assert(world.countAlive("a") == 2, "4: 2 tagged 'a'")

    world.kill(e2.id)
    world.update(0.0)
    assert(killLog.value.len() == 1, "4: 1 kill logged")
    assert(killLog.value[0] == e2.id, "4: killed entity id matches")
    assert(world.count() == 2, "4: 2 after kill+update")

    world.clear()
    assert(clearCount.value == 1, "4: clear signal fired")
    assert(world.count() == 0, "4: empty after clear")
}
entity_world_signals()

// ── 5. Entity + Vec2: movement & collision ───────────────────
fn entity_movement_collision() {
    let world = EntityWorld::new() @[T: String]

    let a = world.spawnFull(0.0, 0.0, 100.0, 0.0, 20.0, 20.0, "a", "left")
    let b = world.spawnFull(50.0, 0.0, -100.0, 0.0, 20.0, 20.0, "b", "right")

    assert(!a.overlapsAABB(b), "5: no overlap initially")

    world.update(0.2)
    assert(a.overlapsAABB(b), "5: overlap after move")
    assert(a.pos.x > 0.0, "5: a moved right")
    assert(b.pos.x < 50.0, "5: b moved left")
}
entity_movement_collision()

// ── 6. Entity query + forEach ────────────────────────────────
fn entity_query() {
    let world = EntityWorld::new() @[T: Int]
    for let i = 0; i < 10; i += 1 {
        let tag = if i % 2 == 0 { "even" } else { "odd" }
        world.spawn(Cast::float(i).unwrap(), 0.0, tag, i)
    }
    assert(world.count() == 10, "6: 10 entities")

    let evens = world.query("even")
    assert(evens.len() == 5, "6: 5 even entities")

    let sum = Box(0)
    world.forEachTagged("odd", |e: Entity(Int)| {
        sum.value += e.data
    })
    assert(sum.value == 25, "6: sum of odd data = 25")

    let found = world.getById(evens[0].id)
    assert(found.isSome(), "6: found by id")
}
entity_query()

// ── 7. Container layout: VBox / HBox sizing ──────────────────
fn container_layouts() {
    let drawCount = Box(0)

    fn makeSlot(sw: Int, sh: Int, counter: Box(Int)) -> Slot {
        return Slot::new(
            |x: Int, y: Int, w: Int, h: Int| { counter.value += 1 },
            fn() -> (Int, Int) { return (sw, sh) }
        )
    }

    let vbox = VBox::new(0, 0, 200)
    vbox.spacing = 10
    vbox.padding = 5
    vbox.add(makeSlot(200, 30, drawCount))
    vbox.add(makeSlot(200, 40, drawCount))
    vbox.add(makeSlot(200, 50, drawCount))

    let totalH = vbox.totalHeight()
    assert(totalH == 150, "7: VBox totalHeight = 150, got " + Cast::string(totalH))

    let hbox = HBox::new(0, 0, 100)
    hbox.spacing = 5
    hbox.padding = 10
    hbox.add(makeSlot(60, 100, drawCount))
    hbox.add(makeSlot(80, 100, drawCount))

    let totalW = hbox.totalWidth()
    assert(totalW == 165, "7: HBox totalWidth = 165, got " + Cast::string(totalW))
}
container_layouts()

// ── 8. Container: GridBox dimensions ─────────────────────────
fn grid_dimensions() {
    let grid = GridBox::new(0, 0, 4, 50, 30)
    grid.spacingX = 5
    grid.spacingY = 5
    grid.padding = 10

    let counter = Box(0)
    for let i = 0; i < 12; i += 1 {
        grid.add(Slot::new(
            |x: Int, y: Int, w: Int, h: Int| { counter.value += 1 },
            fn() -> (Int, Int) { return (50, 30) }
        ))
    }

    let gw = grid.totalWidth()
    let gh = grid.totalHeight()
    assert(gw == 235, "8: grid width = 235, got " + Cast::string(gw))
    assert(gh == 120, "8: grid height = 120, got " + Cast::string(gh))
}
grid_dimensions()

// ── 9. Container: MarginBox ──────────────────────────────────
fn margin_nesting() {
    let innerDrawn = Box(false)

    let child = Slot::new(
        |x: Int, y: Int, w: Int, h: Int| { innerDrawn.value = true },
        fn() -> (Int, Int) { return (100, 50) }
    )
    let margin = MarginBox::new(child, 10, 20, 10, 20)

    let ps = margin.preferredSize()
    assert(ps[0] == 140, "9: margin width 140, got " + Cast::string(ps[0]))
    assert(ps[1] == 70, "9: margin height 70, got " + Cast::string(ps[1]))

    margin.draw(0, 0, 200, 100)
    assert(innerDrawn.value, "9: inner child was drawn")
}
margin_nesting()

// ── 10. Color module: palette + math ─────────────────────────
fn color_operations() {
    let w = color::white()
    assert(w == (255, 255, 255), "10: white is (255,255,255)")

    let b = color::black()
    assert(b == (0, 0, 0), "10: black is (0,0,0)")

    let r = color::red()
    assert(r[0] == 230, "10: red r=230")

    let custom = color::rgb(128, 64, 32)
    assert(custom[0] == 128, "10: custom r")
    assert(custom[1] == 64, "10: custom g")
    assert(custom[2] == 32, "10: custom b")

    let inv = color::invert(color::rgb(100, 150, 200))
    assert(inv[0] == 155, "10: invert r")
    assert(inv[1] == 105, "10: invert g")
    assert(inv[2] == 55, "10: invert b")

    let mid = color::lerpColor(color::black(), color::white(), 0.5)
    assert(mid[0] >= 127, "10: lerp mid r >= 127")
    assert(mid[0] <= 128, "10: lerp mid r <= 128")
}
color_operations()

// ── 11. Signal + Container: event-driven layout updates ──────
fn signal_container_combo() {
    let itemCount = Box(0)
    let onItemAdded = Signal::new() @[T: String]

    let vbox = VBox::new(0, 0, 200)

    onItemAdded.connect(|name: String| {
        itemCount.value += 1
        let n = name
        vbox.add(Slot::new(
            |x: Int, y: Int, w: Int, h: Int| { },
            fn() -> (Int, Int) { return (200, 30) }
        ))
    })

    onItemAdded.emit("Button1")
    onItemAdded.emit("Button2")
    onItemAdded.emit("Label1")

    assert(itemCount.value == 3, "11: 3 items added")
    assert(vbox.slots.len() == 3, "11: 3 slots in vbox")
    assert(vbox.totalHeight() > 0, "11: vbox has height")
}
signal_container_combo()

// ── 12. Entity + Color: entity with color data ───────────────
fn entity_with_color() {
    struct ColoredData {
        hp: Int,
        r: Int,
        g: Int,
        b: Int,
    }

    let world = EntityWorld::new() @[T: ColoredData]

    let c = color::red()
    let e = world.spawn(100.0, 200.0, "enemy", ColoredData {
        hp: 50,
        r: c[0],
        g: c[1],
        b: c[2],
    })

    assert(e.data.hp == 50, "12: entity hp")
    assert(e.data.r == 230, "12: entity red channel from color::red")
    assert(e.tag == "enemy", "12: entity tag")

    e.data.hp -= 20
    let newC = color::green()
    e.data.r = newC[0]
    e.data.g = newC[1]
    e.data.b = newC[2]

    assert(e.data.hp == 30, "12: damaged hp")
    assert(e.data.g == 228, "12: now green")
}
entity_with_color()

// ── 13. SignalBus + HashMap: event-driven scoreboard ─────────
fn event_scoreboard() {
    let bus = SignalBus::new()
    let scores = HashMap::new() @[K: String, V: Int]

    bus.register("kill")
    bus.register("bonus")

    let sc = scores
    bus.connect("kill", || {
        let cur = sc.getOrDefault("player", 0)
        sc.insert("player", cur + 10)
    })

    bus.connect("bonus", || {
        let cur = sc.getOrDefault("player", 0)
        sc.insert("player", cur + 50)
    })

    for let i = 0; i < 5; i += 1 { bus.emit("kill") }
    bus.emit("bonus")

    let finalScore = scores.get("player").unwrap()
    assert(finalScore == 100, "13: 5*10 + 50 = 100")
}
event_scoreboard()

// ── 14. Signal chain: signal fires signal ────────────────────
fn signal_chain() {
    let log = Box([]: String)

    let onHit   = Signal::new() @[T: Int]
    let onDeath = VoidSignal::new()

    let hp = Box(50)

    onHit.connect(|dmg: Int| {
        hp.value -= dmg
        log.value.push("hit:" + Cast::string(dmg))
        if hp.value <= 0 {
            onDeath.emit()
        }
    })

    onDeath.connect(|| {
        log.value.push("death")
    })

    onHit.emit(20)
    assert(hp.value == 30, "14: hp after 20 dmg")
    assert(log.value.len() == 1, "14: just hit logged")

    onHit.emit(40)
    assert(hp.value == -10, "14: hp after 40 more")
    assert(log.value.len() == 3, "14: hit + death logged")
    assert(log.value[2] == "death", "14: death in chain")
}
signal_chain()

// ── 15. EntityWorld + killAll + queries ──────────────────────
fn entity_killAll_query() {
    let world = EntityWorld::new() @[T: String]
    for let i = 0; i < 10; i += 1 {
        world.spawn(0.0, 0.0, "bullet", "b" + Cast::string(i))
    }
    for let i = 0; i < 3; i += 1 {
        world.spawn(0.0, 0.0, "enemy", "e" + Cast::string(i))
    }
    assert(world.count() == 13, "15: 13 total")

    world.killAll("bullet")
    world.update(0.0)
    assert(world.count() == 3, "15: only 3 enemies remain")
    assert(world.countAlive("enemy") == 3, "15: 3 enemies alive")
    assert(world.countAlive("bullet") == 0, "15: 0 bullets")
}
entity_killAll_query()

// ── 16. Container + Box: dynamic slot content ────────────────
fn dynamic_container() {
    let label = Box("Hello")
    let drawnTexts = Box([]: String)

    let slot = Slot::new(
        |x: Int, y: Int, w: Int, h: Int| {
            drawnTexts.value.push(label.value)
        },
        fn() -> (Int, Int) { return (100, 20) }
    )

    let vbox = VBox::new(0, 0, 100)
    vbox.add(slot)

    vbox.draw()
    assert(drawnTexts.value[0] == "Hello", "16: first draw shows Hello")

    label.value = "World"
    vbox.draw()
    assert(drawnTexts.value[1] == "World", "16: second draw shows World")
}
dynamic_container()

// ── 17. Vec2 + Entity: distance-based logic ──────────────────
fn vec2_entity_distance() {
    let world = EntityWorld::new() @[T: Float]
    let player = world.spawn(0.0, 0.0, "player", 0.0)
    let enemy1 = world.spawn(3.0, 4.0, "enemy", 0.0)
    let enemy2 = world.spawn(100.0, 100.0, "enemy", 0.0)

    let d1 = player.pos.distance(enemy1.pos)
    let d2 = player.pos.distance(enemy2.pos)

    assert(d1 > 4.9 && d1 < 5.1, "17: distance to enemy1 ~ 5")
    assert(d2 > 140.0, "17: enemy2 is far away")

    let enemies = world.query("enemy")
    let closest = Box(enemies[0])
    let closestDist = Box(player.pos.distance(enemies[0].pos))
    for e in enemies {
        let d = player.pos.distance(e.pos)
        if d < closestDist.value {
            closestDist.value = d
            closest.value = e
        }
    }
    assert(closest.value.id == enemy1.id, "17: closest is enemy1")
}
vec2_entity_distance()

// ── 18. Multiple signals on one entity world ─────────────────
fn multi_signal_world() {
    let world = EntityWorld::new() @[T: Int]

    let spawnCount = Box(0)
    let killCount  = Box(0)

    world.onSpawn.connect(|id: Int| { spawnCount.value += 1 })
    world.onSpawn.connect(|id: Int| { spawnCount.value += 100 })
    world.onKill.connect(|id: Int| { killCount.value += 1 })

    let e1 = world.spawn(0.0, 0.0, "a", 1)
    let e2 = world.spawn(0.0, 0.0, "b", 2)

    assert(spawnCount.value == 202, "18: 2 spawns * (1+100) = 202")

    world.kill(e1.id)
    world.update(0.0)
    assert(killCount.value == 1, "18: 1 kill")
}
multi_signal_world()

// ── 19. Stress: signals + entities in tight loop ─────────────
fn signal_entity_stress() {
    let total = Box(0)
    let sig = Signal::new() @[T: Int]
    sig.connect(|v: Int| { total.value += v })

    let world = EntityWorld::new() @[T: Int]
    for let i = 0; i < 200; i += 1 {
        let e = world.spawn(Cast::float(i).unwrap(), 0.0, "obj", i)
        sig.emit(i)
    }

    assert(world.count() == 200, "19: 200 entities")
    assert(total.value == 19900, "19: sum 0..199 = 19900")

    world.clear()
    assert(world.count() == 0, "19: cleared")
}
signal_entity_stress()

// ── 20. Color + palette generation ───────────────────────────
fn color_palette_gen() {
    let palette = []: (Int, Int, Int)

    for let i = 0; i < 5; i += 1 {
        let v = i * 64
        if v > 255 { v = 255 }
        palette.push(color::rgb(v, v, v))
    }

    assert(palette.len() == 5, "20: 5 colors in palette")
    assert(palette[0] == (0, 0, 0), "20: first is black")
    assert(palette[4][0] == 255, "20: last clamped to 255")

    let base = color::blue()
    let lighter = color::lighten(base, 0.5)
    let darker  = color::darken(base, 0.5)

    assert(lighter[0] >= base[0], "20: lighten r >= base r")
    assert(lighter[1] >= base[1], "20: lighten g >= base g")
    assert(darker[0] <= base[0], "20: darken r <= base r")
    assert(darker[2] <= base[2], "20: darken b <= base b")
}
color_palette_gen()

