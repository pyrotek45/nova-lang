module test_module_conventions

// Tests for Nova project conventions and module system behavior

// ===== GROUP 1: Module declaration =====
// Every .nv file should start with `module name`
// The name establishes the module identity for deduplication

// This file's module is "test_module_conventions" (declared above)
// If we import it again, it should be deduplicated (no errors)

println("  GROUP 1 [module declaration] OK")

// ===== GROUP 2: Import brings all names into scope =====
import super.std.core

// After import, all public names are available without prefix
let b1 = Box(100)
assert(b1.value == 100, "import scope: Box")

let g = Gen(10)
assert(g() == 10, "import scope: Gen")
assert(g() == 11, "import scope: Gen increment")

let r = range(4)
assert(r.len() == 4, "import scope: range")
assert(r[0] == 0, "import scope: range start")
assert(r[3] == 3, "import scope: range end")

println("  GROUP 2 [import scope] OK")

// ===== GROUP 3: Multiple imports compose =====
import super.std.math
import super.std.string

// Functions from different modules work together
let nums = range(5)
let total = 0
for i in 0..nums.len() {
    total = total + nums[i]
}
assert(total == 10, "compose: range + loop sum")

assert(3.pow(3) == 27, "compose: math pow")
assert((-7).abs() == 7, "compose: math abs")

let s = "hello world"
let words = s.split(' ')
assert(words.len() == 2, "compose: string split")

println("  GROUP 3 [multi-import composition] OK")

// ===== GROUP 4: Enum variants via :: syntax =====
// :: is for enum constructors and static functions, not module access

let ok_val = Result::Ok(42) @[B: String]
let err_val = Result::Err("bad") @[A: Int]

assert(ok_val.isOk(), "enum variant: Result::Ok")
assert(!err_val.isOk(), "enum variant: Result::Err")

let maybe_val = Maybe::Just(99)
let nothing_val = Maybe::Nothing() @[A: Int]

assert(maybe_val.isJust(), "enum variant: Maybe::Just")
assert(nothing_val.isNothing(), "enum variant: Maybe::Nothing")

println("  GROUP 4 [enum :: syntax] OK")

// ===== GROUP 5: Built-in :: functions =====
// Cast::, Float::, Int:: are built-in, not imported

let float_pi = Float::pi()
assert(float_pi > 3.14, "builtin: Float::pi > 3.14")
assert(float_pi < 3.15, "builtin: Float::pi < 3.15")

let cast_str = Cast::string(42)
assert(cast_str == "42", "builtin: Cast::string(42)")

let cast_int_opt = Cast::int("123")
assert(cast_int_opt.isSome(), "builtin: Cast::int isSome")
assert(cast_int_opt.unwrap() == 123, "builtin: Cast::int value")

let bad_cast = Cast::int("abc")
assert(!bad_cast.isSome(), "builtin: Cast::int bad parse")

println("  GROUP 5 [built-in :: functions] OK")

// ===== GROUP 6: Extension methods from imports =====
import super.std.list

// List extensions should work on list values
let xs = [5, 3, 1, 4, 2]
let sorted = xs.bubblesort()
assert(sorted[0] == 1, "extension: bubblesort[0]")
assert(sorted[4] == 5, "extension: bubblesort[4]")

// Math extensions on number values
assert(10.min(3) == 3, "extension: min")
assert(10.max(20) == 20, "extension: max")
assert(5.clamp(1, 3) == 3, "extension: clamp above")
assert(0.clamp(1, 3) == 1, "extension: clamp below")

println("  GROUP 6 [extension methods] OK")

// ===== GROUP 7: Option type (built-in + core extensions) =====
let some_val = Some(42)
let none_val : Option(Int) = None(Int)

assert(some_val.isSome(), "option: Some isSome")
assert(!none_val.isSome(), "option: None not isSome")
assert(some_val.unwrap() == 42, "option: unwrap Some")

// Core extends Option with orDefault and orDoFn
assert(some_val.orDefault(0) == 42, "option ext: orDefault Some")
assert(none_val.orDefault(99) == 99, "option ext: orDefault None")

let lazy_val = none_val.orDoFn(|| 777)
assert(lazy_val == 777, "option ext: orDoFn None")

println("  GROUP 7 [option built-in + extensions] OK")

println("\nAll 7 groups passed")
println("PASS: test_module_conventions")
