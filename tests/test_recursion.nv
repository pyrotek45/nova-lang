module test_recursion

// Simple recursion
fn factorial(n: Int) -> Int {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}
assert(factorial(0) == 1, "factorial 0")
assert(factorial(1) == 1, "factorial 1")
assert(factorial(5) == 120, "factorial 5")
assert(factorial(10) == 3628800, "factorial 10")

// Fibonacci
fn fib(n: Int) -> Int {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
assert(fib(0) == 0, "fib 0")
assert(fib(1) == 1, "fib 1")
assert(fib(2) == 1, "fib 2")
assert(fib(10) == 55, "fib 10")
assert(fib(15) == 610, "fib 15")

// Sum of list recursively
fn sum(list: [Int], index: Int) -> Int {
    if index >= list.len() {
        return 0
    }
    return list[index] + sum(list, index + 1)
}
assert(sum([1, 2, 3, 4, 5], 0) == 15, "recursive sum")

// Power function
fn power(base: Int, exp: Int) -> Int {
    if exp == 0 {
        return 1
    }
    return base * power(base, exp - 1)
}
assert(power(2, 0) == 1, "power 2^0")
assert(power(2, 10) == 1024, "power 2^10")
assert(power(3, 4) == 81, "power 3^4")

// GCD
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 {
        return a
    }
    return gcd(b, a % b)
}
assert(gcd(12, 8) == 4, "gcd 12,8")
assert(gcd(100, 75) == 25, "gcd 100,75")
assert(gcd(7, 13) == 1, "gcd 7,13")

// Mutual recursion - Nova doesn't support forward declarations,
// so we implement even/odd via a single accumulator approach
fn is_even(n: Int) -> Bool {
    if n == 0 {
        return true
    }
    if n == 1 {
        return false
    }
    return is_even(n - 2)
}

fn is_odd(n: Int) -> Bool {
    if n == 0 {
        return false
    }
    if n == 1 {
        return true
    }
    return is_odd(n - 2)
}

assert(is_even(0), "mutual rec even 0")
assert(!is_odd(0), "mutual rec odd 0")
assert(is_even(10), "mutual rec even 10")
assert(is_odd(11), "mutual rec odd 11")
assert(!is_even(7), "mutual rec not even 7")
assert(!is_odd(8), "mutual rec not odd 8")

// Deep recursion (testing stack)
fn count_down(n: Int) -> Int {
    if n == 0 {
        return 0
    }
    return count_down(n - 1)
}
assert(count_down(1000) == 0, "deep recursion 1000")

// Ackermann-like (limited)
fn ack(m: Int, n: Int) -> Int {
    if m == 0 {
        return n + 1
    }
    if n == 0 {
        return ack(m - 1, 1)
    }
    return ack(m - 1, ack(m, n - 1))
}
assert(ack(0, 0) == 1, "ack 0,0")
assert(ack(1, 1) == 3, "ack 1,1")
assert(ack(2, 2) == 7, "ack 2,2")
assert(ack(3, 2) == 29, "ack 3,2")

// ---- Accumulator-style tail recursion ----
fn fact_acc(n: Int, acc: Int) -> Int {
    if n <= 1 { return acc }
    return fact_acc(n - 1, n * acc)
}
assert(fact_acc(5, 1) == 120, "tail-acc factorial 5")
assert(fact_acc(10, 1) == 3628800, "tail-acc factorial 10")

// ---- Sum digits recursively ----
fn sum_digits(n: Int) -> Int {
    if n < 10 { return n }
    return n % 10 + sum_digits(n / 10)
}
assert(sum_digits(0) == 0, "sum_digits 0")
assert(sum_digits(9) == 9, "sum_digits 9")
assert(sum_digits(123) == 6, "sum_digits 123")
assert(sum_digits(9999) == 36, "sum_digits 9999")

// ---- Count digits recursively ----
fn count_digits(n: Int) -> Int {
    if n < 10 { return 1 }
    return 1 + count_digits(n / 10)
}
assert(count_digits(0) == 1, "count_digits 0")
assert(count_digits(9) == 1, "count_digits 9")
assert(count_digits(100) == 3, "count_digits 100")
assert(count_digits(999999) == 6, "count_digits 999999")

// ---- Reverse a list recursively ----
fn rev(lst: [Int]) -> [Int] {
    if lst.len() == 0 { return []: Int }
    let head = lst[0]
    let tail = lst[1:lst.len()]
    let reversed_tail = rev(tail)
    reversed_tail.push(head)
    return reversed_tail
}
assert(rev([]: Int).len() == 0, "rev empty")
assert(rev([1])[0] == 1, "rev singleton")
let reversed = rev([1, 2, 3, 4, 5])
assert(reversed[0] == 5, "rev[0]=5")
assert(reversed[4] == 1, "rev[4]=1")

// ---- Flatten nested depth via recursion ----
fn flatten_depth(lst: [Int], depth: Int) -> Int {
    if depth == 0 { return lst.len() }
    return flatten_depth(lst, depth - 1)
}
assert(flatten_depth([1,2,3], 5) == 3, "flatten_depth trivial")

// ---- Binary search recursively ----
fn bsearch(lst: [Int], target: Int, lo: Int, hi: Int) -> Int {
    if lo > hi { return -1 }
    let mid = (lo + hi) / 2
    if lst[mid] == target { return mid }
    if lst[mid] < target { return bsearch(lst, target, mid + 1, hi) }
    return bsearch(lst, target, lo, mid - 1)
}
let sorted = [1, 3, 5, 7, 9, 11, 13, 15]
assert(bsearch(sorted, 1, 0, 7) == 0, "bsearch first element")
assert(bsearch(sorted, 15, 0, 7) == 7, "bsearch last element")
assert(bsearch(sorted, 7, 0, 7) == 3, "bsearch middle")
assert(bsearch(sorted, 6, 0, 7) == -1, "bsearch not found")

println("PASS: test_recursion")
