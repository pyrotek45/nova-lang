// ═══════════════════════════════════════════════
// GROUP 8: Option type
// ═══════════════════════════════════════════════
group("option_type")

let some_v: Option(Int) = Some(42)
let none_v: Option(Int) = None(Int)

check(some_v.isSome(), "Some isSome")
check(!none_v.isSome(), "None !isSome")
check(some_v.unwrap() == 42, "Some unwrap")

// orDefault
check(some_v.orDefault(0) == 42, "Some orDefault")
check(none_v.orDefault(99) == 99, "None orDefault")

// isNone
check(none_v.isNone(), "None isNone")
check(!some_v.isNone(), "Some !isNone")

// if let
let if_let_res = 0
if let val = some_v {
    if_let_res = val + 1
}
check(if_let_res == 43, "if let Some")

let if_let_none = -1
if let val2 = none_v {
    if_let_none = val2
}
check(if_let_none == -1, "if let None")

// map
let mapped_opt = some_v.map(|x: Int| x * 2)
check(mapped_opt.isSome(), "map Some isSome")
check(mapped_opt.unwrap() == 84, "map Some val")

let mapped_none = none_v.map(|x: Int| x * 2)
check(mapped_none.isNone(), "map None isNone")

// filter
let filt_pass = some_v.filter(|x: Int| x > 10)
check(filt_pass.isSome(), "filter pass")
let filt_fail = some_v.filter(|x: Int| x > 100)
check(filt_fail.isNone(), "filter fail")

// toList
let to_list_some = some_v.toList()
check(to_list_some.len() == 1, "toList Some len")
check(to_list_some[0] == 42, "toList Some[0]")
let to_list_none = none_v.toList()
check(to_list_none.len() == 0, "toList None len")

println("  GROUP 8 [option_type] OK")

// ═══════════════════════════════════════════════
// GROUP 9: HashMap operations
// ═══════════════════════════════════════════════
group("hashmap_ops")

let hm = HashMap::default() @[K: String, V: Int]
check(hm.isEmpty(), "new map isEmpty")
check(hm.size() == 0, "new map size")

hm.insert("a", 1)
hm.insert("b", 2)
hm.insert("c", 3)
check(hm.size() == 3, "map size after inserts")
check(!hm.isEmpty(), "map not empty")
check(hm.has("a"), "has a")
check(!hm.has("z"), "!has z")

let got = hm.get("b")
check(got.isSome(), "get b isSome")
check(got.unwrap() == 2, "get b == 2")

let got_none = hm.get("z")
check(!got_none.isSome(), "get z isNone")

// getOrDefault
check(hm.getOrDefault("a", 0) == 1, "getOrDefault existing")
check(hm.getOrDefault("z", 99) == 99, "getOrDefault missing")

// delete
hm.delete("b")
check(hm.size() == 2, "size after delete")
check(!hm.has("b"), "deleted key gone")

// keys and values
let ks = hm.keys()
check(ks.len() == 2, "keys len")
let vs = hm.values()
check(vs.len() == 2, "values len")

// entries
let ents = hm.entries()
check(ents.len() == 2, "entries len")

// clear
hm.clear()
check(hm.size() == 0, "after clear size")
check(hm.isEmpty(), "after clear isEmpty")

// fromPairs
let hm2 = HashMap::fromPairs([("x", 10), ("y", 20)]) @[K: String, V: Int]
check(hm2.size() == 2, "fromPairs size")
check(hm2.get("x").unwrap() == 10, "fromPairs get x")

// increment
let counter = HashMap::default() @[K: String, V: Int]
counter.insert("hits", 0)
counter.increment("hits")
counter.increment("hits")
counter.increment("hits")
check(counter.get("hits").unwrap() == 3, "increment 3x")

println("  GROUP 9 [hashmap_ops] OK")

// ═══════════════════════════════════════════════
// GROUP 10: Set operations
// ═══════════════════════════════════════════════
group("set_ops")

let s1 = Set::empty() @[T: Int]
check(s1.size() == 0, "empty set size")

s1.add(1)
s1.add(2)
s1.add(3)
check(s1.size() == 3, "set size 3")
check(s1.has(1), "set has 1")
check(s1.has(2), "set has 2")
check(!s1.has(99), "set !has 99")

// Duplicate add (no-op for sets)
s1.add(2)
check(s1.size() == 3, "set no dup")

// Remove
s1.remove(2)
check(s1.size() == 2, "set after remove")
check(!s1.has(2), "set removed 2")

// fromList dedup
let s2 = Set::fromList([1, 2, 2, 3, 3, 3])
check(s2.size() == 3, "fromList dedup")
check(s2.has(1), "fromList has 1")
check(s2.has(3), "fromList has 3")

// singleton
let s3 = Set::singleton(42)
check(s3.size() == 1, "singleton size")
check(s3.has(42), "singleton has")

println("  GROUP 10 [set_ops] OK")

// ═══════════════════════════════════════════════
// GROUP 11: Iterators
// ═══════════════════════════════════════════════
group("iterators")

// fromVec -> collect
let it1 = Iter::fromVec([1, 2, 3, 4, 5]).collect()
check(it1.len() == 5, "iter collect len")
check(it1[0] == 1, "iter collect[0]")

// map
let it2 = Iter::fromVec([1, 2, 3]).map(|x: Int| x * x).collect()
check(it2.len() == 3, "iter map len")
check(it2[0] == 1, "iter map[0]")
check(it2[2] == 9, "iter map[2]")

// filter
let it3 = Iter::fromVec([1, 2, 3, 4, 5, 6]).filter(|x: Int| x % 2 == 0).collect()
check(it3.len() == 3, "iter filter len")
check(it3[0] == 2, "iter filter[0]")

// chained map+filter
let it4 = Iter::fromVec([1, 2, 3, 4, 5])
    .map(|x: Int| x * 2)
    .filter(|x: Int| x > 4)
    .collect()
check(it4.len() == 3, "iter chain len")
check(it4[0] == 6, "iter chain[0]")
check(it4[2] == 10, "iter chain[2]")

// take
let it5 = Iter::fromVec([10, 20, 30, 40, 50]).take(3).collect()
check(it5.len() == 3, "iter take len")
check(it5[2] == 30, "iter take[2]")

// drop
let it6 = Iter::fromVec([10, 20, 30, 40, 50]).drop(2).collect()
check(it6.len() == 3, "iter drop len")
check(it6[0] == 30, "iter drop[0]")

// sum
let it_sum = Iter::fromVec([1, 2, 3, 4, 5]).sum()
check(it_sum == 15, "iter sum")

// count
let it_count = Iter::fromVec([1, 2, 3]).count()
check(it_count == 3, "iter count")

// any / all
let it_any = Iter::fromVec([1, 2, 3, 4]).any(|x: Int| x > 3)
check(it_any, "iter any")
let it_all = Iter::fromVec([2, 4, 6]).all(|x: Int| x % 2 == 0)
check(it_all, "iter all")

// find
let found = Iter::fromVec([10, 20, 30, 40]).find(|x: Int| x > 25)
check(found.isSome(), "iter find isSome")
check(found.unwrap() == 30, "iter find val")

println("  GROUP 11 [iterators] OK")

// ═══════════════════════════════════════════════
// GROUP 12: Structs and extends
// ═══════════════════════════════════════════════
group("structs_extends")

struct Point { x: Int, y: Int }

fn extends magnitude_sq(pt: Point) -> Int {
    return pt.x * pt.x + pt.y * pt.y
}

fn extends translate(pt: Point, dx: Int, dy: Int) -> Point {
    return Point { x: pt.x + dx, y: pt.y + dy }
}

fn extends(Point) origin() -> Point {
    return Point { x: 0, y: 0 }
}

let ori = Point::origin()
check(ori.x == 0, "origin x")
check(ori.y == 0, "origin y")

let p1 = Point { x: 3, y: 4 }
check(p1.magnitude_sq() == 25, "magnitude 3,4")

let p2 = p1.translate(10, 20)
check(p2.x == 13, "translate x")
check(p2.y == 24, "translate y")

// Positional construction
let p3 = Point(5, 12)
check(p3.magnitude_sq() == 169, "positional struct")

// Field mutation
let p4 = Point(0, 0)
p4.x = 7
p4.y = 24
check(p4.magnitude_sq() == 625, "field mutation")

// type field
check(p4.type == "Point", "struct type field")

// Aliasing
let p5 = p4
p5.x = 100
check(p4.x == 100, "struct aliasing")

// Clone
let p6 = clone(p4)
p6.x = 0
check(p4.x == 100, "clone independence")

println("  GROUP 12 [structs_extends] OK")

// ═══════════════════════════════════════════════
// GROUP 13: Enums and pattern matching
// ═══════════════════════════════════════════════
group("enums_matching")

enum Shape {
    Circle: Float,
    Rect: (Float, Float),
    Dot
}

fn extends area(s: Shape) -> Float {
    match s {
        Circle(r) => { return 3.14159 * r * r }
        Rect(dims) => { return dims[0] * dims[1] }
        Dot() => { return 0.0 }
    }
    return 0.0
}

let circ = Shape::Circle(5.0)
let r_area = circ.area()
check(r_area > 78.0, "circle area > 78")
check(r_area < 79.0, "circle area < 79")

let rect = Shape::Rect((4.0, 5.0))
check(rect.area() == 20.0, "rect area")

let dot = Shape::Dot()
check(dot.area() == 0.0, "dot area")

// Maybe enum from std/core
let just_v = Maybe::Just(42)
let nothing_v = Maybe::Nothing() @[A: Int]

check(just_v.isJust(), "Maybe isJust")
check(nothing_v.isNothing(), "Maybe isNothing")
check(just_v.unwrap() == 42, "Maybe unwrap")
check(nothing_v.orDefault(99) == 99, "Maybe orDefault")

// Result enum
let ok_v = Result::Ok(10) @[B: String]
let err_v = Result::Err("bad") @[A: Int]

check(ok_v.isOk(), "Result isOk")
check(err_v.isErr(), "Result isErr")
check(ok_v.unwrap() == 10, "Result unwrap")
check(err_v.unwrapErr() == "bad", "Result unwrapErr")

println("  GROUP 13 [enums_matching] OK")

// ═══════════════════════════════════════════════
// GROUP 14: Closures and higher-order functions
// ═══════════════════════════════════════════════
group("closures_hof")

// Basic closure
let add_fn = fn(a: Int, b: Int) -> Int { return a + b }
check(add_fn(3, 4) == 7, "closure call")

// Lambda
let sq = |x: Int| x * x
check(sq(5) == 25, "lambda")

// Closure capturing
let offset = 100
let add_offset = |x: Int| x + offset
check(add_offset(5) == 105, "closure capture")

// Box for mutable shared state
let ctr = Box(0)
let inc = fn() -> Int { ctr.value = ctr.value + 1; return ctr.value }
check(inc() == 1, "Box inc 1")
check(inc() == 2, "Box inc 2")
check(inc() == 3, "Box inc 3")

// Function reference with @
fn triple(x: Int) -> Int { return x * 3 }
let ref_fn = triple@(Int)
check(ref_fn(10) == 30, "fn reference")

// Closure factory
fn make_adder(n: Int) -> fn(Int) -> Int {
    return |x: Int| x + n
}
let add5 = make_adder(5)
let add10 = make_adder(10)
check(add5(3) == 8, "adder 5+3")
check(add10(3) == 13, "adder 10+3")

// Closure as arg to higher-order
fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    return f(f(x))
}
check(apply_twice(|x: Int| x + 1, 0) == 2, "apply_twice inc")
check(apply_twice(|x: Int| x * 2, 3) == 12, "apply_twice double")

// Pipe operator
fn double_val(x: Int) -> Int { return x * 2 }
fn inc_val(x: Int) -> Int { return x + 1 }
let pipe_r = 5 |> inc_val() |> double_val()
check(pipe_r == 12, "pipe (5+1)*2 == 12")

println("  GROUP 14 [closures_hof] OK")

// ═══════════════════════════════════════════════
// GROUP 15: Control flow edge cases
// ═══════════════════════════════════════════════
group("control_flow")

// Nested if/elif/else
fn classify(x: Int) -> String {
    if x < 0 {
        return "negative"
    } elif x == 0 {
        return "zero"
    } elif x < 10 {
        return "small"
    } elif x < 100 {
        return "medium"
    } else {
        return "large"
    }
}
check(classify(-5) == "negative", "classify -5")
check(classify(0) == "zero", "classify 0")
check(classify(5) == "small", "classify 5")
check(classify(50) == "medium", "classify 50")
check(classify(100) == "large", "classify 100")

// Break from nested loop
let outer_count = Box(0)
for let ii = 0; ii < 10; ii += 1 {
    for let jj = 0; jj < 10; jj += 1 {
        if jj == 3 { break }
        outer_count.value = outer_count.value + 1
    }
}
// Each outer iteration runs inner 0,1,2 then breaks = 3 per outer * 10 = 30
check(outer_count.value == 30, "nested break count")

// Continue in loop
let cont_sum = 0
for let ii2 = 0; ii2 < 10; ii2 += 1 {
    if ii2 % 2 == 0 { continue }
    cont_sum = cont_sum + ii2
}
// 1 + 3 + 5 + 7 + 9 = 25
check(cont_sum == 25, "continue odd sum")

// While with break
let wv = 0
while true {
    wv = wv + 1
    if wv >= 5 { break }
}
check(wv == 5, "while break")

// For-in range exclusive
let range_sum = 0
for ri in 0..5 {
    range_sum = range_sum + ri
}
check(range_sum == 10, "range 0..5 sum")

// For-in range inclusive
let range_inc_sum = 0
for ri2 in 0..=5 {
    range_inc_sum = range_inc_sum + ri2
}
check(range_inc_sum == 15, "range 0..=5 sum")

// For-in collection
let col = [10, 20, 30]
let col_sum = 0
for item in col {
    col_sum = col_sum + item
}
check(col_sum == 60, "for-in collection sum")

println("  GROUP 15 [control_flow] OK")

// ═══════════════════════════════════════════════
// GROUP 16: Clone and aliasing
// ═══════════════════════════════════════════════
group("clone_aliasing")

// List aliasing
let orig_l = [1, 2, 3]
let alias_l = orig_l
alias_l.push(4)
check(orig_l.len() == 4, "list alias shared push")

// List clone
let orig_l2 = [10, 20, 30]
let copy_l2 = clone(orig_l2)
copy_l2.push(40)
check(orig_l2.len() == 3, "cloned list independent")
check(copy_l2.len() == 4, "cloned list has push")

// Struct clone
struct Data { val: Int, items: [Int] }
let d1 = Data { val: 1, items: [10, 20] }
let d2 = clone(d1)
d2.val = 99
d2.items.push(30)
check(d1.val == 1, "clone struct val independent")
check(d1.items.len() == 2, "clone struct nested list independent")

// String aliasing - strings alias too
let s_orig = "hello"
let s_alias = s_orig
// strings are immutable-ish via concat (creates new)
let s_new = s_alias + " world"
// original unchanged
check(s_orig == "hello", "string concat doesn't mutate")

println("  GROUP 16 [clone_aliasing] OK")

// ═══════════════════════════════════════════════
// GROUP 17: Dyn types
// ═══════════════════════════════════════════════
group("dyn_types")

struct Dog { name: String, age: Int }
struct Robot { name: String, model: Int }

fn get_name(thing: Dyn(T = name: String)) -> String {
    return thing.name
}

let dog = Dog { name: "Rex", age: 5 }
let robot = Robot { name: "R2D2", model: 2 }

check(get_name(dog) == "Rex", "dyn Dog name")
check(get_name(robot) == "R2D2", "dyn Robot name")

// Multi-field dyn
fn get_info(x: Dyn(T = name: String + age: Int)) -> String {
    return x.name + ":" + Cast::string(x.age)
}
check(get_info(dog) == "Rex:5", "multi-field dyn")

println("  GROUP 17 [dyn_types] OK")

// ═══════════════════════════════════════════════
// GROUP 18: Bind operator and syntax sugar
// ═══════════════════════════════════════════════
group("syntax_sugar")

// Bind operator ~>
let bind_r = 42 ~> x { x + 8 }
check(bind_r == 50, "bind 42 ~> x+8")

let bind_r2 = [1, 2, 3, 4, 5].len() ~> n { n * n }
check(bind_r2 == 25, "bind len ~> n*n")

// If expression
let if_expr = if true { 10 } else { 20 }
check(if_expr == 10, "if expr true")
let if_expr2 = if false { 10 } else { 20 }
check(if_expr2 == 20, "if expr false")

// Compound assignment
let ca = 10
ca += 5
check(ca == 15, "+=")
ca -= 3
check(ca == 12, "-=")
ca = ca / 4
check(ca == 3, "manual /=")

// Format
let fmt = format("Hello {}! Age {}", ["Alice", "30"])
check(fmt == "Hello Alice! Age 30", "format")

// Trailing closure
fn apply_tc(x: Int, f: fn(Int) -> Int) -> Int { return f(x) }
let tc_r = apply_tc(5): |x: Int| x * 3
check(tc_r == 15, "trailing closure")

println("  GROUP 18 [syntax_sugar] OK")

// ═══════════════════════════════════════════════
// GROUP 19: Generic structs
// ═══════════════════════════════════════════════
group("generic_structs")

struct Wrapper(T) { value: $T }

let w1 = Wrapper { value: 42 }
check(w1.value == 42, "Wrapper(Int)")

let w2 = Wrapper { value: "hello" }
check(w2.value == "hello", "Wrapper(String)")

let w3 = Wrapper { value: [1, 2, 3] }
check(w3.value.len() == 3, "Wrapper([Int])")

struct Pair2(A, B) { fst: $A, snd: $B }

fn extends swap_pair(p_in: Pair2($A, $B)) -> Pair2($B, $A) {
    return Pair2 { fst: p_in.snd, snd: p_in.fst }
}

let pr = Pair2 { fst: 1, snd: "one" }
check(pr.fst == 1, "Pair fst")
check(pr.snd == "one", "Pair snd")

let swapped = pr.swap_pair()
check(swapped.fst == "one", "swap fst")
check(swapped.snd == 1, "swap snd")

println("  GROUP 19 [generic_structs] OK")

// ═══════════════════════════════════════════════
// GROUP 20: Struct function fields (:: and ->)
// ═══════════════════════════════════════════════
group("struct_fn_fields")

struct Processor {
    name: String,
    process: fn(String) -> String
}

let upper_proc = Processor {
    name: "upper",
    process: |s: String| s.toUpper()
}
let result_proc = upper_proc::process("hello")
check(result_proc == "HELLO", ":: fn field call")

struct Handler {
    label: String,
    handle: fn(Handler, String) -> String
}

let hnd = Handler {
    label: "test",
    handle: fn(self: Handler, msg: String) -> String {
        return self.label + ": " + msg
    }
}
let hnd_result = hnd->handle("hi")
check(hnd_result == "test: hi", "-> fn field call with self")

println("  GROUP 20 [struct_fn_fields] OK")

