module perf_function_calls

// ============================================================
// Function Call Overhead Benchmarks
// ============================================================
// Tests: DCALL, RET, stack frame setup/teardown, UFCS dispatch,
//   argument passing, return value handling, overload resolution
// ============================================================

// ── BENCH 1: Simple function call ───────────────────────────
fn add_one(x: Int) -> Int { return x + 1 }

let t1 = now()
let s1 = 0
for i in 0..200000 {
    s1 = add_one(s1)
}
let t1e = now()
assert(s1 == 200000, "simple call")
println("  BENCH 1 [simple_call_200k]     " + Cast::string(t1e - t1) + "ms")

// ── BENCH 2: Multi-arg function call ────────────────────────
fn sum3(a: Int, b: Int, c: Int) -> Int { return a + b + c }

let t2 = now()
let s2 = 0
for i in 0..100000 {
    s2 = s2 + sum3(i, 1, 2)
}
let t2e = now()
assert(s2 > 0, "multi-arg call")
println("  BENCH 2 [multi_arg_100k]       " + Cast::string(t2e - t2) + "ms")

// ── BENCH 3: UFCS extends call ──────────────────────────────
fn extends dbl(x: Int) -> Int { return x * 2 }

let t3 = now()
let s3 = 0
for i in 0..200000 {
    s3 = i.dbl()
}
let t3e = now()
assert(s3 == 399998, "UFCS call")
println("  BENCH 3 [ufcs_call_200k]       " + Cast::string(t3e - t3) + "ms")

// ── BENCH 4: Chained UFCS calls ─────────────────────────────
fn extends inc(x: Int) -> Int { return x + 1 }
fn extends triple(x: Int) -> Int { return x * 3 }

let t4 = now()
let s4 = 0
for i in 0..100000 {
    s4 = s4 + i.inc().dbl().triple()
}
let t4e = now()
assert(s4 > 0, "chained UFCS")
println("  BENCH 4 [chained_ufcs_100k]    " + Cast::string(t4e - t4) + "ms")

// ── BENCH 5: Recursive function call ────────────────────────
fn sum_to(n: Int) -> Int {
    if n <= 0 { return 0 }
    return n + sum_to(n - 1)
}

let t5 = now()
let s5 = 0
for i in 0..1000 {
    s5 = s5 + sum_to(100)
}
let t5e = now()
assert(s5 == 5050000, "recursive call")
println("  BENCH 5 [recursive_100x1k]     " + Cast::string(t5e - t5) + "ms")

// ── BENCH 6: Function returning struct ──────────────────────
struct Pt { x: Int, y: Int }
fn make_pt(a: Int, b: Int) -> Pt { return Pt { x: a, y: b } }

let t6 = now()
let s6 = 0
for i in 0..100000 {
    let p = make_pt(i, i + 1)
    s6 = s6 + p.x
}
let t6e = now()
assert(s6 == 4999950000, "fn returning struct")
println("  BENCH 6 [fn_return_struct_100k] " + Cast::string(t6e - t6) + "ms")

// ── BENCH 7: Overloaded function dispatch ───────────────────
fn dispatch(x: Int) -> Int { return x + 1 }
fn dispatch(x: String) -> Int { return x.len() }

let t7 = now()
let s7 = 0
for i in 0..100000 {
    s7 = s7 + dispatch(i)
}
let t7e = now()
assert(s7 > 0, "overloaded dispatch")
println("  BENCH 7 [overload_100k]        " + Cast::string(t7e - t7) + "ms")

// ── BENCH 8: Void function call (side-effect) ───────────────
let void_counter = [0]
fn void_inc() { void_counter[0] = void_counter[0] + 1 }

let t8 = now()
for i in 0..200000 {
    void_inc()
}
let t8e = now()
assert(void_counter[0] == 200000, "void call")
println("  BENCH 8 [void_call_200k]       " + Cast::string(t8e - t8) + "ms")

// ── BENCH 9: Function reference call ────────────────────────
fn square(x: Int) -> Int { return x * x }
let sq_ref = square@(Int)

let t9 = now()
let s9 = 0
for i in 0..100000 {
    s9 = s9 + sq_ref(i)
}
let t9e = now()
assert(s9 > 0, "fn ref call")
println("  BENCH 9 [fn_ref_call_100k]     " + Cast::string(t9e - t9) + "ms")

// ── BENCH 10: Mutual recursion ──────────────────────────────
fn even_r(n: Int) -> Bool
fn odd_r(n: Int) -> Bool

fn even_r(n: Int) -> Bool {
    if n == 0 { return true }
    return odd_r(n - 1)
}
fn odd_r(n: Int) -> Bool {
    if n == 0 { return false }
    return even_r(n - 1)
}

let t10 = now()
let s10 = 0
for i in 0..5000 {
    if even_r(100) { s10 = s10 + 1 }
}
let t10e = now()
assert(s10 == 5000, "mutual recursion")
println("  BENCH 10 [mutual_recur_5k]     " + Cast::string(t10e - t10) + "ms")

// ── Summary ─────────────────────────────────────────────────
println("")
let total = (t1e-t1)+(t2e-t2)+(t3e-t3)+(t4e-t4)+(t5e-t5)+(t6e-t6)+(t7e-t7)+(t8e-t8)+(t9e-t9)+(t10e-t10)
println("  TOTAL [function_calls] " + Cast::string(total) + "ms")
