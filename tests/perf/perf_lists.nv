module perf_lists

import super.super.std.list
import super.super.std.core

// ============================================================
// List Operations Benchmarks
// ============================================================
// Tests: push, pop, indexing, map, filter, reduce, sort,
//   slice, comprehensions, concat, flatten
// ============================================================

// ── BENCH 1: Push throughput ────────────────────────────────
let t1 = now()
let list1 = []: Int
for i in 0..100000 {
    list1.push(i)
}
let t1e = now()
assert(list1.len() == 100000, "push")
println("  BENCH 1 [push_100k]            " + Cast::string(t1e - t1) + "ms")

// ── BENCH 2: Pop throughput ─────────────────────────────────
let list2 = []: Int
for i in 0..50000 {
    list2.push(i)
}
let t2 = now()
for i in 0..50000 {
    let _ = list2.pop()
}
let t2e = now()
assert(list2.len() == 0, "pop")
println("  BENCH 2 [pop_50k]              " + Cast::string(t2e - t2) + "ms")

// ── BENCH 3: Index read throughput ──────────────────────────
let list3 = 0.to(10000)
let t3 = now()
let s3 = 0
for i in 0..10000 {
    s3 = s3 + list3[i]
}
let t3e = now()
assert(s3 == 49995000, "index read")
println("  BENCH 3 [index_read_10k]       " + Cast::string(t3e - t3) + "ms")

// ── BENCH 4: Index write throughput ─────────────────────────
let list4 = []: Int
for i in 0..10000 {
    list4.push(0)
}
let t4 = now()
for i in 0..10000 {
    list4[i] = i * 2
}
let t4e = now()
assert(list4[5000] == 10000, "index write")
println("  BENCH 4 [index_write_10k]      " + Cast::string(t4e - t4) + "ms")

// ── BENCH 5: Map operation ──────────────────────────────────
let list5 = 0.to(10000)
let t5 = now()
let mapped = list5.map(|x: Int| x * 3 + 1)
let t5e = now()
assert(mapped.len() == 10000, "map len")
assert(mapped[0] == 1, "map first")
println("  BENCH 5 [map_10k]              " + Cast::string(t5e - t5) + "ms")

// ── BENCH 6: Filter operation ───────────────────────────────
let list6 = 0.to(20000)
let t6 = now()
let filtered = list6.filter(|x: Int| x % 3 == 0)
let t6e = now()
assert(filtered.len() > 0, "filter")
println("  BENCH 6 [filter_20k]           " + Cast::string(t6e - t6) + "ms")

// ── BENCH 7: Reduce operation ───────────────────────────────
let list7 = 0.to(10000)
let t7 = now()
let total = list7.reduce(|acc: Int, x: Int, i: Int| acc + x, 0)
let t7e = now()
assert(total == 49995000, "reduce")
println("  BENCH 7 [reduce_10k]           " + Cast::string(t7e - t7) + "ms")

// ── BENCH 8: Quicksort ─────────────────────────────────────
let list8 = []: Int
for i in 0..2000 {
    list8.push(2000 - i)
}
let t8 = now()
let sorted = list8.quicksort()
let t8e = now()
assert(sorted[0] == 1, "sort first")
assert(sorted[1999] == 2000, "sort last")
println("  BENCH 8 [quicksort_2k]         " + Cast::string(t8e - t8) + "ms")

// ── BENCH 9: Slice operation ────────────────────────────────
let list9 = 0.to(10000)
let t9 = now()
let s9 = 0
for i in 0..1000 {
    let sl = list9.slice(i, i + 100)
    s9 = s9 + sl.len()
}
let t9e = now()
assert(s9 == 100000, "slice")
println("  BENCH 9 [slice_1k]             " + Cast::string(t9e - t9) + "ms")

// ── BENCH 10: Concat operation ──────────────────────────────
let t10 = now()
let big = []: Int
for i in 0..1000 {
    let chunk = [i, i+1, i+2]
    big = big.concat(chunk)
}
let t10e = now()
assert(big.len() == 3000, "concat")
println("  BENCH 10 [concat_1k]           " + Cast::string(t10e - t10) + "ms")

// ── BENCH 11: Flatten nested lists ──────────────────────────
let nested = []: [Int]
for i in 0..500 {
    nested.push([i, i+1, i+2, i+3, i+4])
}
let t11 = now()
let flat = nested.flatten()
let t11e = now()
assert(flat.len() == 2500, "flatten")
println("  BENCH 11 [flatten_500x5]       " + Cast::string(t11e - t11) + "ms")

// ── BENCH 12: List comprehension ────────────────────────────
let t12 = now()
let comp = [x in 0.to(10000) | x * 2]
let t12e = now()
assert(comp.len() == 10000, "comprehension")
assert(comp[0] == 0, "comp first")
println("  BENCH 12 [comprehension_10k]   " + Cast::string(t12e - t12) + "ms")

// ── Summary ─────────────────────────────────────────────────
println("")
let total_time = (t1e-t1)+(t2e-t2)+(t3e-t3)+(t4e-t4)+(t5e-t5)+(t6e-t6)+(t7e-t7)+(t8e-t8)+(t9e-t9)+(t10e-t10)+(t11e-t11)+(t12e-t12)
println("  TOTAL [lists] " + Cast::string(total_time) + "ms")
