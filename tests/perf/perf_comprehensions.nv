module perf_comprehensions

// ═════════════════════════════════════════════════════════════
// List comprehension & pipeline performance benchmarks
// ═════════════════════════════════════════════════════════════

import super.super.std.core
import super.super.std.list

// ── BENCH 1: simple comprehension ───────────────────────────
let t1 = now()
let s1 = 0
for round in 0..200 {
    let xs = [x in 0.to(1000) | x * 2]
    s1 = s1 + xs.len()
}
let t1e = now()
assert(s1 == 200000, "simple comprehension")
println("  BENCH 1 [comprehension_200k]     " + Cast::string(t1e - t1) + "ms")

// ── BENCH 2: filtered comprehension ─────────────────────────
let t2 = now()
let s2 = 0
for round in 0..200 {
    let xs = [x in 0.to(1000) | x | x % 2 == 0]
    s2 = s2 + xs.len()
}
let t2e = now()
assert(s2 == 100000, "filtered comprehension")
println("  BENCH 2 [filtered_comp_200x1k]   " + Cast::string(t2e - t2) + "ms")

// ── BENCH 3: nested comprehension (cross product) ───────────
let t3 = now()
let s3 = 0
for round in 0..50 {
    let xs = [x in 0.to(100), y in 0.to(100) | x + y]
    s3 = s3 + xs.len()
}
let t3e = now()
assert(s3 > 0, "nested comprehension")
println("  BENCH 3 [nested_comp_50x100x100] " + Cast::string(t3e - t3) + "ms")

// ── BENCH 4: comprehension with math expr ───────────────────
let t4 = now()
let s4 = 0
for round in 0..200 {
    let xs = [x in 0.to(1000) | x * x + x * 3 + 7]
    s4 = s4 + xs.len()
}
let t4e = now()
assert(s4 == 200000, "math comprehension")
println("  BENCH 4 [math_comp_200k]         " + Cast::string(t4e - t4) + "ms")

// ── BENCH 5: map chain ──────────────────────────────────────
let t5 = now()
let s5 = 0
for round in 0..200 {
    let base = 0.to(1000)
    let ys = base.map(|x: Int| x * 2).map(|x: Int| x + 1)
    s5 = s5 + ys.len()
}
let t5e = now()
assert(s5 == 200000, "map chain")
println("  BENCH 5 [map_chain_200k]         " + Cast::string(t5e - t5) + "ms")

// ── BENCH 6: filter chain ───────────────────────────────────
let t6 = now()
let s6 = 0
for round in 0..200 {
    let base = 0.to(1000)
    let ys = base.filter(|x: Int| x % 2 == 0).filter(|x: Int| x % 3 == 0)
    s6 = s6 + ys.len()
}
let t6e = now()
assert(s6 > 0, "filter chain")
println("  BENCH 6 [filter_chain_200k]      " + Cast::string(t6e - t6) + "ms")

// ── BENCH 7: reduce accumulation ────────────────────────────
let t7 = now()
let s7 = 0
for round in 0..500 {
    let base = 0.to(1000)
    let total = base.reduce(|acc: Int, x: Int, i: Int| acc + x, 0)
    s7 = s7 + total
}
let t7e = now()
assert(s7 > 0, "reduce")
println("  BENCH 7 [reduce_500x1k]          " + Cast::string(t7e - t7) + "ms")

// ── BENCH 8: map + filter + reduce pipeline ─────────────────
let t8 = now()
let s8 = 0
for round in 0..200 {
    let base = 0.to(1000)
    let mapped = base.map(|x: Int| x * 2)
    let filtered = mapped.filter(|x: Int| x % 4 == 0)
    let total = filtered.reduce(|acc: Int, x: Int, i: Int| acc + x, 0)
    s8 = s8 + total
}
let t8e = now()
assert(s8 > 0, "pipeline")
println("  BENCH 8 [pipeline_200x1k]        " + Cast::string(t8e - t8) + "ms")

// ── BENCH 9: large comprehension ────────────────────────────
let t9 = now()
let s9 = 0
for round in 0..10 {
    let xs = [x in 0.to(10000) | x * 3]
    s9 = s9 + xs.len()
}
let t9e = now()
assert(s9 == 100000, "large comprehension")
println("  BENCH 9 [large_comp_10x10k]      " + Cast::string(t9e - t9) + "ms")

// ── BENCH 10: comprehension with multi-guard ────────────────
let t10 = now()
let s10 = 0
for round in 0..200 {
    let xs = [x in 0.to(1000) | x | x % 2 == 0 | x % 5 == 0]
    s10 = s10 + xs.len()
}
let t10e = now()
assert(s10 > 0, "multi guard comprehension")
println("  BENCH 10 [multi_guard_comp_200k] " + Cast::string(t10e - t10) + "ms")

// ── summary ─────────────────────────────────────────────────
let total = (t1e - t1) + (t2e - t2) + (t3e - t3) + (t4e - t4) + (t5e - t5) + (t6e - t6) + (t7e - t7) + (t8e - t8) + (t9e - t9) + (t10e - t10)
println("")
println("  TOTAL [comprehensions] " + Cast::string(total) + "ms")
