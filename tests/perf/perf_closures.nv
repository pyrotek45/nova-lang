module perf_closures

import super.super.std.core

// ============================================================
// Closure Benchmarks
// ============================================================
// Tests: closure creation, captured variable access, Box mutation,
//   factory pattern, HOF apply, closure in loop, callback overhead
// ============================================================

// ── BENCH 1: Closure creation overhead ──────────────────────
let t1 = now()
let s1 = 0
for i in 0..100000 {
    let f = |x: Int| x + 1
    s1 = f(i)
}
let t1e = now()
assert(s1 == 100000, "creation")
println("  BENCH 1 [closure_create_100k]  " + Cast::string(t1e - t1) + "ms")

// ── BENCH 2: Captured variable read ─────────────────────────
let captured_val = 42
fn get_captured() -> Int { return captured_val }
let t2 = now()
let s2 = 0
for i in 0..200000 {
    s2 = s2 + get_captured()
}
let t2e = now()
assert(s2 == 8400000, "capture read")
println("  BENCH 2 [capture_read_200k]    " + Cast::string(t2e - t2) + "ms")

// ── BENCH 3: Box mutation in closure ────────────────────────
let counter = Box(0)
let inc = || { counter.value += 1 }
let t3 = now()
for i in 0..200000 {
    inc()
}
let t3e = now()
assert(counter.value == 200000, "box mutation")
println("  BENCH 3 [box_mutate_200k]      " + Cast::string(t3e - t3) + "ms")

// ── BENCH 4: Closure factory pattern ────────────────────────
fn make_adder(n: Int) -> fn(Int) -> Int {
    return |x: Int| x + n
}

let t4 = now()
let s4 = 0
for i in 0..50000 {
    let add5 = make_adder(5)
    s4 = s4 + add5(i)
}
let t4e = now()
assert(s4 > 0, "factory")
println("  BENCH 4 [factory_50k]          " + Cast::string(t4e - t4) + "ms")

// ── BENCH 5: HOF apply ─────────────────────────────────────
fn apply_fn(f: fn(Int) -> Int, x: Int) -> Int {
    return f(x)
}

let t5 = now()
let s5 = 0
for i in 0..100000 {
    s5 = s5 + apply_fn(|x: Int| x * 2, i)
}
let t5e = now()
assert(s5 > 0, "HOF apply")
println("  BENCH 5 [hof_apply_100k]       " + Cast::string(t5e - t5) + "ms")

// ── BENCH 6: Closure chain (compose) ────────────────────────
fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int) -> fn(Int) -> Int {
    return |x: Int| f(g(x))
}

let double = |x: Int| x * 2
let plus1 = |x: Int| x + 1

let t6 = now()
let s6 = 0
for i in 0..50000 {
    let composed = compose(double, plus1)
    s6 = s6 + composed(i)
}
let t6e = now()
assert(s6 > 0, "compose")
println("  BENCH 6 [compose_50k]          " + Cast::string(t6e - t6) + "ms")

// ── BENCH 7: Closure as callback ────────────────────────────
fn with_callback(val: Int, cb: fn(Int)) {
    cb(val)
}

let cb_sum = Box(0)
let t7 = now()
for i in 0..100000 {
    with_callback(i, |v: Int| { cb_sum.value = cb_sum.value + v })
}
let t7e = now()
assert(cb_sum.value > 0, "callback")
println("  BENCH 7 [callback_100k]        " + Cast::string(t7e - t7) + "ms")

// ── BENCH 8: Closure capturing loop var ─────────────────────
let t8 = now()
let closures = []: fn() -> Int
for i in 0..1000 {
    let val = i
    closures.push(fn() -> Int { return val })
}
let s8 = 0
for c in closures {
    s8 = s8 + c()
}
let t8e = now()
assert(s8 == 499500, "loop capture")
println("  BENCH 8 [loop_capture_1k]      " + Cast::string(t8e - t8) + "ms")

// ── BENCH 9: Multiple captures ──────────────────────────────
let t9 = now()
let s9 = 0
for i in 0..50000 {
    let a = i
    let b = i + 1
    let c = i + 2
    let f = fn() -> Int { return a + b + c }
    s9 = s9 + f()
}
let t9e = now()
assert(s9 > 0, "multi capture")
println("  BENCH 9 [multi_capture_50k]    " + Cast::string(t9e - t9) + "ms")

// ── BENCH 10: Stateful closure (counter) ────────────────────
fn make_counter() -> fn() -> Int {
    let state = Box(0)
    return fn() -> Int {
        state.value += 1
        return state.value
    }
}

let t10 = now()
let ctr = make_counter()
let s10 = 0
for i in 0..100000 {
    s10 = ctr()
}
let t10e = now()
assert(s10 == 100000, "stateful counter")
println("  BENCH 10 [stateful_ctr_100k]   " + Cast::string(t10e - t10) + "ms")

// ── Summary ─────────────────────────────────────────────────
println("")
let total = (t1e-t1)+(t2e-t2)+(t3e-t3)+(t4e-t4)+(t5e-t5)+(t6e-t6)+(t7e-t7)+(t8e-t8)+(t9e-t9)+(t10e-t10)
println("  TOTAL [closures] " + Cast::string(total) + "ms")
