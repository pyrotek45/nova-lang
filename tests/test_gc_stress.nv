module test_gc_stress

import super.std.core
import super.std.list

// ============================================================
// Deep GC Stress Tests — ref counting + sweep & collect
// ============================================================

// ---- Helpers ----
struct Payload {
    id: Int,
    data: [Int],
    tag: String
}

// 1. Thousands of short-lived struct allocations
fn short_lived_structs() {
    for let i = 0; i < 1000; i += 1 {
        let p = Payload { id: i, data: [i, i*2, i*3], tag: "p" + Cast::string(i) }
    }
}
short_lived_structs()
assert(true, "1000 short-lived structs freed")

// 2. Long-lived list of structs grows then drops
fn long_lived_struct_list() {
    let pool = []: Payload
    for let i = 0; i < 500; i += 1 {
        pool.push(Payload { id: i, data: [i], tag: "pool" })
    }
    assert(pool.len() == 500, "pool length 500")
    // Drop all — replace with empty list
    pool = []: Payload
    assert(pool.len() == 0, "pool emptied")
}
long_lived_struct_list()

// 3. Closure captures struct ref; struct outlives closure scope
fn closure_captures_struct() {
    let results = []: Int
    for let i = 0; i < 20; i += 1 {
        let captured = i
        let f = fn() -> Int { return captured * captured }
        results.push(f())
    }
    assert(results[0] == 0, "closure capture 0")
    assert(results[5] == 25, "closure capture 5")
    assert(results[19] == 361, "closure capture 19")
}
closure_captures_struct()

// 4. Deep recursive allocation — builds a spine then releases
fn build_spine(n: Int) -> [[Int]] {
    if n == 0 {
        return [[0]]
    }
    let tail = build_spine(n - 1)
    let head = [n, n, n]
    tail.push(head)
    return tail
}
let spine = build_spine(100)
assert(spine.len() == 101, "spine length")
spine = []: [Int]
assert(spine.len() == 0, "spine released")

// 5. Many Box(T) allocations — each is a heap object
fn box_stress() {
    let boxes = []: Box(Int)
    for let i = 0; i < 200; i += 1 {
        boxes.push(Box(i))
    }
    assert(boxes[0].value == 0, "box 0")
    assert(boxes[199].value == 199, "box 199")
    // Mutate via Box
    boxes[100].value = 9999
    assert(boxes[100].value == 9999, "box mutated")
}
box_stress()

// 6. Function values stored in list and discarded
fn fn_list_gc() {
    let fs = []: fn() -> Int
    for let i = 0; i < 300; i += 1 {
        let v = i
        fs.push(fn() -> Int { return v })
    }
    let sum = 0
    for let i = 0; i < fs.len(); i += 1 {
        sum = sum + fs[i]()
    }
    // sum = 0+1+...+299 = 299*300/2 = 44850
    assert(sum == 44850, "fn list gc sum")
}
fn_list_gc()

// 7. Repeatedly reassigning a Box (old value must be freed)
fn box_reassign() {
    let b = Box(0)
    for let i = 0; i < 500; i += 1 {
        b.value = i
    }
    assert(b.value == 499, "box final value after 500 reassigns")
}
box_reassign()

// 8. Nested closures — multi-level captures
fn nested_closures_gc() -> fn() -> fn() -> Int {
    let outer = Box(10)
    return fn() -> fn() -> Int {
        let inner = Box(outer.value + 5)
        return fn() -> Int {
            return inner.value * 2
        }
    }
}
let make_inner = nested_closures_gc()
let get_val = make_inner()
assert(get_val() == 30, "nested closure value (10+5)*2=30")

// 9. Struct with function field — gc must track fn pointers
struct Counter {
    value: Int,
    inc: fn(Counter) -> Int
}

fn CounterNew() -> Counter {
    return Counter {
        value: 0,
        inc: fn(self: Counter) -> Int {
            self.value = self.value + 1
            return self.value
        }
    }
}

fn counter_fn_gc() {
    let counters = []: Counter
    for let i = 0; i < 50; i += 1 {
        counters.push(CounterNew())
    }
    // Increment each counter twice
    for let i = 0; i < counters.len(); i += 1 {
        counters[i]->inc()
        counters[i]->inc()
    }
    assert(counters[0].value == 2, "counter fn gc value 0")
    assert(counters[49].value == 2, "counter fn gc value 49")
}
counter_fn_gc()

// 10. Interleaved alloc/free pressure with strings
fn string_interleave() {
    let live = []: String
    for let i = 0; i < 200; i += 1 {
        live.push("alive_" + Cast::string(i))
        if i % 10 == 9 {
            // Drop half
            let keep = []: String
            for let j = 0; j < live.len(); j += 2 {
                keep.push(live[j])
            }
            live = keep
        }
    }
    assert(live.len() > 0, "strings survived interleave")
}
string_interleave()

// 11. Generator pattern — Box used as iterator state
fn make_counter_gen(start: Int) -> fn() -> Int {
    let i = Box(start)
    return fn() -> Int {
        let cur = i.value
        i.value = i.value + 1
        return cur
    }
}

let gen1 = make_counter_gen(0)
let gen2 = make_counter_gen(100)

for let i = 0; i < 10; i += 1 {
    gen1()
    gen2()
}
assert(gen1() == 10, "gen1 at 10")
assert(gen2() == 110, "gen2 at 110")

// 12. Many Option allocations
fn option_gc_stress() {
    let opts = []: Option(String)
    for let i = 0; i < 300; i += 1 {
        if i % 2 == 0 {
            opts.push(Some("value_" + Cast::string(i)))
        } else {
            opts.push(None(String))
        }
    }
    let some_count = 0
    let none_count = 0
    for let i = 0; i < opts.len(); i += 1 {
        if opts[i].isSome() {
            some_count = some_count + 1
        } else {
            none_count = none_count + 1
        }
    }
    assert(some_count == 150, "option gc some count")
    assert(none_count == 150, "option gc none count")
}
option_gc_stress()

// 13. Closure over a mutable list — list survives multiple closure calls
fn shared_list_closure() {
    let log = Box([]: String)
    let record = fn(s: String) {
        log.value.push(s)
    }
    for let i = 0; i < 50; i += 1 {
        record("entry_" + Cast::string(i))
    }
    assert(log.value.len() == 50, "shared list closure 50 entries")
    assert(log.value[0] == "entry_0", "first entry correct")
    assert(log.value[49] == "entry_49", "last entry correct")
}
shared_list_closure()

// 14. Recursive struct (via list) deep nesting — tests cycle handling
fn recursive_struct_pressure() {
    // Build a list-of-lists (simulates tree nodes)
    let nodes = []: [[Int]]
    for let i = 0; i < 100; i += 1 {
        let children = []: [Int]
        for let j = 0; j < 10; j += 1 {
            children.push([i, j, i * j])
        }
        nodes.push(children)
    }
    assert(nodes.len() == 100, "100 nodes")
    assert(nodes[50].len() == 10, "50th node has 10 children")
    assert(nodes[5][3][2] == 15, "nodes[5][3][2] = 5*3 = 15")
    // Release all
    nodes = []: [[Int]]
    assert(nodes.len() == 0, "recursive nodes released")
}
recursive_struct_pressure()

// 15. Multiple Box objects cross-referencing via fn values
fn box_cross_ref() {
    let a = Box(0)
    let b = Box(0)
    let inc_a = fn() { a.value = a.value + 1 }
    let inc_b = fn() { b.value = b.value + 1 }
    let sync = fn() {
        inc_a()
        inc_b()
    }
    for let i = 0; i < 100; i += 1 {
        sync()
    }
    assert(a.value == 100, "box cross ref a=100")
    assert(b.value == 100, "box cross ref b=100")
}
box_cross_ref()

// 16. Large string allocations and concatenation churn
fn string_churn() {
    let result = ""
    for let i = 0; i < 100; i += 1 {
        result = result + "x"
    }
    assert(result.len() == 100, "string churn length 100")
    // Now build from pieces
    let pieces = []: String
    for let i = 0; i < 50; i += 1 {
        pieces.push(Cast::string(i) + ".")
    }
    let joined = ""
    for x in pieces {
        joined = joined + x
    }
    assert(joined.len() > 0, "joined string non-empty")
}
string_churn()

// 17. Deep option chain: wrap/unwrap 50 times each
fn option_chain_stress() {
    let values = []: Option(Int)
    for let i = 0; i < 50; i += 1 {
        values.push(Some(i * 3))
    }
    let total = 0
    for let i = 0; i < values.len(); i += 1 {
        if values[i].isSome() {
            total = total + values[i].unwrap()
        }
    }
    // sum of 0*3, 1*3, ..., 49*3 = 3*(0+1+...+49) = 3*1225 = 3675
    assert(total == 3675, "option chain sum 3675")
}
option_chain_stress()

// 18. Struct holding a Box(String) — layered heap allocation
struct TextBox {
    content: Box(String),
    id: Int
}

fn textbox_gc_stress() {
    let boxes = []: TextBox
    for let i = 0; i < 100; i += 1 {
        boxes.push(TextBox {
            content: Box("item_" + Cast::string(i)),
            id: i
        })
    }
    assert(boxes[0].content.value == "item_0", "textbox 0")
    assert(boxes[99].content.value == "item_99", "textbox 99")
    // Mutate a few
    boxes[10].content.value = "mutated"
    assert(boxes[10].content.value == "mutated", "textbox 10 mutated")
    // Release
    boxes = []: TextBox
    assert(boxes.len() == 0, "textboxes released")
}
textbox_gc_stress()

// 19. Accumulator pattern with many closures sharing the same Box
fn accumulator_stress() {
    let acc = Box(0)
    let adders = []: fn(Int) -> Int
    for let i = 0; i < 100; i += 1 {
        let step = i
        adders.push(fn(x: Int) -> Int {
            acc.value = acc.value + step
            return acc.value
        })
    }
    // call each adder with 1
    for let i = 0; i < adders.len(); i += 1 {
        adders[i](1)
    }
    // acc = 0+1+2+...+99 = 4950
    assert(acc.value == 4950, "accumulator stress sum=4950")
}
accumulator_stress()

// 20. Rapid Box creation and immediate release (tight loop)
fn box_rapid_release() {
    let last = 0
    for let i = 0; i < 10000; i += 1 {
        let b = Box(i)
        last = b.value
    }
    assert(last == 9999, "box rapid release last=9999")
}
box_rapid_release()

println("PASS: test_gc_stress")
