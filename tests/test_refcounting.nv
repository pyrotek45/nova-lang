module test_refcounting

import super.std.core
import super.std.list

// ============================================================================
// Reference Counting Semantic Tests
//
// These tests verify that Nova's ref-counting behaves correctly for
// the most common aliasing and sharing patterns: lists referenced from
// other lists, closures capturing variables, function returns, and
// shared mutation through aliases.
//
// Each test documents the expected ref-count semantics in comments and
// verifies the observable behaviour (what the program sees, not internal
// counts, which are not exposed to Nova code).
// ============================================================================

// ── Test 1: List referenced from another list ────────────────────────────────
// v has refcount ≥ 2: one from the binding `v`, one because `t[0]` aliases it.
// Mutating through `t[0]` must be visible via `v` and vice-versa.
let v = [4, 5, 6]
let t = [v]          // t[0] is an alias to v, not a copy

t[0].push(7)
assert(v.len() == 4, "rc1: push via t[0] visible in v")
assert(v[3] == 7,    "rc1: pushed element visible in v")

v.push(8)
assert(t[0].len() == 5, "rc1: push via v visible in t[0]")
assert(t[0][4] == 8,    "rc1: pushed element visible in t[0]")

// ── Test 2: Closure captures a list reference ────────────────────────────────
// The closure `id` returns a fresh closure each call, but every returned
// closure shares the SAME `v` reference (since `v` is captured by reference).
fn id() -> fn() -> [Int] {
    return fn() -> [Int] {
        return v
    }
}

let r = id()
let q = id()

// Both closures must return the live `v`
assert(r() == v,       "rc2: closure r returns v")
assert(q() == v,       "rc2: closure q returns v")
assert(r()[0] == q()[0], "rc2: both closures see same list head")

// Mutating v is visible through all closure returns
v.push(9)
assert(r()[5] == 9, "rc2: push to v visible via r()")
assert(q()[5] == 9, "rc2: push to v visible via q()")

// ── Test 3: Alias semantics — assignment does NOT copy ────────────────────────
let orig = [10, 20, 30]
let alias = orig   // alias and orig point to the same object

alias[0] = 99
assert(orig[0] == 99, "rc3: mutation via alias visible in orig")

orig.push(40)
assert(alias.len() == 4, "rc3: push via orig visible in alias")
assert(alias[3] == 40,   "rc3: element visible in alias")

// ── Test 4: Clone breaks the reference ───────────────────────────────────────
let base = [1, 2, 3]
let independent = clone(base)

independent[0] = 999
assert(base[0] == 1, "rc4: clone is independent — base unchanged")

base.push(4)
assert(independent.len() == 3, "rc4: clone not affected by push to base")

// ── Test 5: Refcount survives function boundary ───────────────────────────────
// Passing a list to a function does not copy it; mutations persist after return.
fn append_one(lst: [Int]) {
    lst.push(100)
}

let shared = [1, 2, 3]
append_one(shared)
assert(shared.len() == 4,   "rc5: function mutated caller's list")
assert(shared[3] == 100,    "rc5: mutation persists after return")

// ── Test 6: Closure captures and keeps alive ─────────────────────────────────
// The captured list `log` should remain alive as long as the closure lives.
fn make_logger() -> fn(String) {
    let log = []: String
    return fn(msg: String) {
        log.push(msg)
    }
}

let logger = make_logger()
logger("a")
logger("b")
logger("c")
// We can't inspect `log` directly since it's captured, but calling the closure
// must not crash — the list must still be alive.
assert(true, "rc6: captured list survives closure calls")

// ── Test 7: Multiple closures sharing one Box ─────────────────────────────────
fn make_shared_counter() -> (fn() -> Int, fn()) {
    let count = Box(0)
    let get = fn() -> Int { return count.value }
    let inc = fn() { count.value = count.value + 1 }
    return (get, inc)
}

let sc = make_shared_counter()
let sc_get = sc[0]
let sc_inc = sc[1]

sc_inc()
sc_inc()
sc_inc()
assert(sc_get() == 3, "rc7: Box shared between closures, count=3")

// Even after the original tuple `sc` is overwritten, the closures keep the Box alive.
sc_inc()
assert(sc_get() == 4, "rc7: Box still alive after tuple dropped")

// ── Test 8: Deeply nested aliasing ───────────────────────────────────────────
let inner = [1, 2, 3]
let mid   = [inner]
let outer2 = [mid]

// outer2[0][0] is the same object as `inner`
outer2[0][0].push(9)
assert(inner.len() == 4,        "rc8: push via outer2 visible in inner")
assert(mid[0].len() == 4,       "rc8: push via outer2 visible in mid[0]")
assert(outer2[0][0].len() == 4, "rc8: outer2 consistent")

// ── Test 9: List elements are refs — removing doesn't clone ──────────────────
let elem = [100, 200]
let container = [elem, [1, 2]]

// container[0] is elem; mutating container[0] mutates elem
container[0].push(300)
assert(elem.len() == 3,         "rc9: push via container[0] visible in elem")
assert(elem[2] == 300,          "rc9: element visible in elem")

// ── Test 10: Refcount under reassignment ─────────────────────────────────────
// When a variable is reassigned, the old object's refcount drops.
// If nothing else holds it, it should be freed.  The new object is then live.
let mutable_ref = [1, 2, 3]
let keeper = mutable_ref  // keep the old list alive

mutable_ref = [10, 20, 30]  // rebind mutable_ref to a new list
mutable_ref.push(40)

assert(mutable_ref[0] == 10,  "rc10: new list after reassign")
assert(mutable_ref[3] == 40,  "rc10: new list extended")
assert(keeper[0] == 1,        "rc10: old list still alive via keeper")
assert(keeper.len() == 3,     "rc10: old list unaffected by new push")

// ── Test 11: fn returning closure keeps environment alive ────────────────────
fn build_adder(n: Int) -> fn(Int) -> Int {
    return fn(x: Int) -> Int { return x + n }
}

let add5  = build_adder(5)
let add10 = build_adder(10)

assert(add5(3)  == 8,  "rc11: closure add5 correct")
assert(add10(3) == 13, "rc11: closure add10 correct")
assert(add5(0)  == 5,  "rc11: closure env still alive")

// ── Test 12: Long chain of aliases, all consistent ───────────────────────────
let root = [0]
let a1 = root
let a2 = a1
let a3 = a2
let a4 = a3

a4.push(1)
assert(root.len() == 2, "rc12: root sees push through 4-alias chain")
assert(a1.len() == 2,   "rc12: a1 consistent")
assert(a2.len() == 2,   "rc12: a2 consistent")
assert(a3.len() == 2,   "rc12: a3 consistent")

root.push(2)
assert(a4.len() == 3,   "rc12: a4 sees push from root")

println("PASS: test_refcounting")
