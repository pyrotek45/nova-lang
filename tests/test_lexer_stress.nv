module test_lexer_stress

import super.std.core
import super.std.list

// ============================================================
// Lexer Stress Tests
// Unicode, escape sequences, number literals, edge cases
// in tokenization
// ============================================================

// ---- String escape sequences ----
let tab_str = "a\tb"
let newline_str = "a\nb"
let backslash_str = "a\\b"
let quote_str = "say \"hello\""

assert(tab_str.len() == 3, "tab escape len")
assert(backslash_str.len() == 3, "backslash escape len")
assert(quote_str.len() == 11, "quoted string len")

// ---- Long identifier names ----
let a_very_long_variable_name_that_tests_the_lexer_limit = 42
let another_quite_long_variable_name_for_good_measure = 100
assert(
    a_very_long_variable_name_that_tests_the_lexer_limit +
    another_quite_long_variable_name_for_good_measure == 142,
    "long identifiers"
)

// ---- Integer literal forms ----
let decimal = 1234567890
let zero = 0
let neg = -999999
assert(decimal == 1234567890, "decimal literal")
assert(zero == 0, "zero literal")
assert(neg == -999999, "negative literal")

// ---- Float literal forms ----
let f1 = 0.0
let f2 = 1.5
let f3 = 123.456
let f4 = -0.001
assert(f1 == 0.0, "float 0.0")
assert(f2 == 1.5, "float 1.5")
assert(f3 == 123.456, "float 123.456")
assert(f4 == -0.001, "float -0.001")

// ---- Char literals ----
let c1 = 'a'
let c2 = 'Z'
let c3 = '0'
let c4 = ' '
let c5 = '\n'
let c6 = '\t'
assert(c1 == 'a', "char a")
assert(c2 == 'Z', "char Z")
assert(c3 == '0', "char 0")
assert(c4 == ' ', "char space")

// ---- Keywords as part of identifiers ----
let lethal = 1       // 'let' prefix
let format2 = 2      // 'for' prefix
let ifconfig = 3     // 'if' prefix
let matchmaker = 4   // 'match' prefix
let trueblue = 5     // 'true' prefix
let false_flag = 6   // 'false' prefix (with underscore)

assert(lethal == 1, "keyword prefix ident lethal")
assert(format2 == 2, "keyword prefix ident format2")
assert(ifconfig == 3, "keyword prefix ident ifconfig")
assert(matchmaker == 4, "keyword prefix ident matchmaker")
assert(trueblue == 5, "keyword prefix ident trueblue")
assert(false_flag == 6, "keyword prefix ident false_flag")

// ---- Operators adjacent with no spaces ----
let x = 5
let r1 = x*2+1
let r2 = x*x-1
let r3 = x+x*x-x/x
assert(r1 == 11, "no-space ops x*2+1")
assert(r2 == 24, "no-space ops x*x-1")
assert(r3 == 29, "no-space ops x+x*x-x/x = 5+25-1=29")

// ---- Comments don't affect parsing ----
let a = 1  // inline comment
// full line comment
let b = 2  /* this isn't valid Nova block comment but just checking inline */
let c = a + b
assert(c == 3, "comments don't break parsing")

// ---- Empty string ----
let empty = ""
assert(empty.len() == 0, "empty string len")
assert(empty == "", "empty string eq")

// ---- Single-char strings ----
let sa = "a"
let sb = "z"
assert(sa.len() == 1, "single char string len")
assert(sa == "a", "single char string eq")

// ---- Operator precedence disambiguation ----
// Nova: * before +, + before ==, == before &&, && before ||
assert(2 + 3 * 4 == 14, "prec: *before+")
assert(2 * 3 + 4 * 5 == 26, "prec: both *before+")
// Nova: || binds tighter than && (note: opposite of many languages)
// true || false = true, then true && false = false -- so add parens when mixing
assert((true || false) && (true || false), "parens mixed bool 1")
assert(!((false || false) && (true || false)), "parens mixed bool 2")
assert(!(false && true || false), "prec: complex bool")

// ---- Negative operator in various positions ----
let neg1 = -1
let neg2 = -(3 + 4)
let neg3 = -(-5)
assert(neg1 == -1, "neg literal")
assert(neg2 == -7, "neg expr")
assert(neg3 == 5, "neg neg")

// ---- Chained comparison-like expressions ----
let p = 3
let q = 5
let in_range = p > 0 && q < 10 && p < q
assert(in_range, "chained comparisons")

// ---- Large string concatenation ----
fn repeat_str(s: String, n: Int) -> String {
    let result = ""
    for let i = 0; i < n; i += 1 {
        result = result + s
    }
    return result
}
let hundred_x = repeat_str("x", 100)
assert(hundred_x.len() == 100, "repeat string length")
assert(hundred_x == repeat_str("x", 100), "repeat string eq")

// ---- Semicolons as statement separators ----
let s1 = 1; let s2 = 2; let s3 = s1 + s2
assert(s3 == 3, "semicolon separated stmts")

// ---- Multi-line expressions ----
let long_expr = 1 +
    2 +
    3 +
    4 +
    5
assert(long_expr == 15, "multi-line expression")

// ---- Deeply nested parens ----
let deep_paren = (((((42)))))
assert(deep_paren == 42, "deeply nested parens")

// ---- Boolean literals in various contexts ----
let t = true
let f = false
assert(t == true, "bool literal true")
assert(f == false, "bool literal false")
assert(t != f, "bool literal ne")
assert(t && !f, "bool literal and-not")

// ---- String with numbers ----
let num_str = "12345"
assert(num_str.len() == 5, "numeric string len")
assert(num_str == "12345", "numeric string eq")

// ---- All comparison operators ----
assert(1 < 2, "lt")
assert(2 > 1, "gt")
assert(2 <= 2, "le eq")
assert(3 <= 4, "le lt")
assert(5 >= 5, "ge eq")
assert(6 >= 5, "ge gt")
assert(1 != 2, "ne")
assert(!(1 != 1), "not ne")

// ---- Integer edge cases ----
let max_reasonable = 1000000000
let min_reasonable = -1000000000
assert(max_reasonable > 0, "large positive int")
assert(min_reasonable < 0, "large negative int")
assert(max_reasonable + min_reasonable == 0, "large ints cancel")

// ---- Float edge cases ----
let tiny = 0.000001
let big_f = 999999.999999
assert(tiny > 0.0, "tiny float positive")
assert(big_f > 999999.0, "big float")
assert(big_f - 999999.0 < 1.0, "big float fractional part")

// ---- Mixed arithmetic precedence exhaustive ----
assert(1 + 2 * 3 - 4 / 2 == 5, "prec: 1+6-2=5")
assert(10 - 3 - 2 == 5, "left assoc subtraction")
assert(10 / 2 / 1 == 5, "left assoc division")
assert(2 * 3 * 4 == 24, "left assoc multiplication")
assert(10 % 3 == 1, "modulo 10%3=1")
assert(10 % 4 == 2, "modulo 10%4=2")
assert(7 % 7 == 0, "modulo self = 0")

// ---- Identifier with all valid chars ----
let _private = 1
let _123 = 2
let abc123def = 3
let ALLCAPS = 4
let MixedCase = 5
assert(_private == 1, "underscore prefix ident")
assert(_123 == 2, "underscore+digit ident")
assert(abc123def == 3, "alphanum ident")
assert(ALLCAPS == 4, "all caps ident")
assert(MixedCase == 5, "mixed case ident")

// ---- Nested string operations ----
fn str_reverse(s: String) -> String {
    let cs = s.chars()
    let result = []: Char
    let len = cs.len()
    for let i = len - 1; i >= 0; i -= 1 {
        result.push(cs[i])
    }
    return result.string()
}
assert(str_reverse("hello") == "olleh", "str reverse hello")
assert(str_reverse("abcde") == "edcba", "str reverse abcde")
assert(str_reverse("") == "", "str reverse empty")
assert(str_reverse("a") == "a", "str reverse single char")

// ---- Deeply nested list operations ----
let matrix = [[1,2,3],[4,5,6],[7,8,9]]
assert(matrix.len() == 3, "matrix rows")
assert(matrix[0].len() == 3, "matrix cols")
assert(matrix[0][0] == 1, "matrix[0][0]=1")
assert(matrix[1][1] == 5, "matrix[1][1]=5")
assert(matrix[2][2] == 9, "matrix[2][2]=9")

// Flatten by hand
fn flatten(m: [[Int]]) -> [Int] {
    let result = []: Int
    for row in m {
        for v in row {
            result.push(v)
        }
    }
    return result
}
let flat = flatten(matrix)
assert(flat.len() == 9, "flatten len 9")
assert(flat[0] == 1, "flatten[0]=1")
assert(flat[4] == 5, "flatten[4]=5")
assert(flat[8] == 9, "flatten[8]=9")

// ---- Complex string escape roundtrips ----
let tab_in_string = "col1\tcol2\tcol3"
assert(tab_in_string.len() == 14, "tab-separated string len")

let quotes_in_str = "He said \"hi\""
assert(quotes_in_str.len() == 12, "embedded quotes len")

let backslash_escape = "path\\to\\file"
assert(backslash_escape.len() == 12, "backslash escape len")

// ---- Number parsing edge cases ----
let zero_int = 0
let zero_float = 0.0
assert(zero_int == 0, "zero int")
assert(zero_float == 0.0, "zero float")
// Arithmetic with zero
assert(zero_int + 100 == 100, "zero + 100")
assert(100 - zero_int == 100, "100 - zero")
assert(zero_int * 9999 == 0, "zero * anything")
assert(0.0 + 1.5 == 1.5, "float zero + 1.5")

// ---- Long chains of boolean operations ----
let b1 = true
let b2 = false
let b3 = true
let b4 = false
let b5 = true
let chain = b1 && !b2 && b3 && !b4 && b5
assert(chain, "long bool chain all satisfy")
let chain2 = b1 || b2 || b3 || b4 || b5
assert(chain2, "long bool or chain any true")
let chain3 = b2 || b4
assert(!chain3, "long bool or chain all false")

// ---- Many local variables in one scope ----
fn twenty_locals() -> Int {
    let a = 1
    let b = 2
    let c = 3
    let d = 4
    let e = 5
    let f = 6
    let g = 7
    let h = 8
    let i = 9
    let j = 10
    let k = 11
    let l = 12
    let m = 13
    let n = 14
    let o = 15
    let p = 16
    let q = 17
    let r = 18
    let s = 19
    let t = 20
    return a+b+c+d+e+f+g+h+i+j+k+l+m+n+o+p+q+r+s+t
}
// 1+2+...+20 = 210
assert(twenty_locals() == 210, "twenty locals sum 1-20=210")

// ---- Operator tokens: all of them back to back ----
let ops_test_a = 10
let ops_test_b = 3
assert(ops_test_a + ops_test_b == 13, "op +")
assert(ops_test_a - ops_test_b == 7, "op -")
assert(ops_test_a * ops_test_b == 30, "op *")
assert(ops_test_a / ops_test_b == 3, "op / integer")
assert(ops_test_a % ops_test_b == 1, "op %")
assert(ops_test_a == ops_test_a, "op ==")
assert(ops_test_a != ops_test_b, "op !=")
assert(ops_test_a > ops_test_b, "op >")
assert(ops_test_b < ops_test_a, "op <")
assert(ops_test_a >= ops_test_a, "op >=")
assert(ops_test_b <= ops_test_b, "op <=")
assert(!false, "op !")
assert(true && true, "op &&")
assert(false || true, "op ||")

println("PASS: test_lexer_stress")
