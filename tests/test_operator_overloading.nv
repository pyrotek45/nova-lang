module test_operator_overloading

// Custom type for operator overloading
struct Vec2 {
    x: Int,
    y: Int,
}

// toString
fn extends toString(self: Vec2) -> String {
    return "(" + Cast::string(self.x) + ", " + Cast::string(self.y) + ")"
}

// __add__
fn extends __add__(self: Vec2, other: Vec2) -> Vec2 {
    return Vec2 { x: self.x + other.x, y: self.y + other.y }
}

let a = Vec2(1, 2)
let b = Vec2(3, 4)
let c = a + b
assert(c.x == 4, "overloaded + x")
assert(c.y == 6, "overloaded + y")

// __sub__
fn extends __sub__(self: Vec2, other: Vec2) -> Vec2 {
    return Vec2 { x: self.x - other.x, y: self.y - other.y }
}

let d = b - a
assert(d.x == 2, "overloaded - x")
assert(d.y == 2, "overloaded - y")

// __mul__
fn extends __mul__(self: Vec2, other: Vec2) -> Vec2 {
    return Vec2 { x: self.x * other.x, y: self.y * other.y }
}

let e = Vec2(2, 3) * Vec2(4, 5)
assert(e.x == 8, "overloaded * x")
assert(e.y == 15, "overloaded * y")

// __div__
fn extends __div__(self: Vec2, other: Vec2) -> Vec2 {
    return Vec2 { x: self.x / other.x, y: self.y / other.y }
}

let f = Vec2(10, 20) / Vec2(2, 5)
assert(f.x == 5, "overloaded / x")
assert(f.y == 4, "overloaded / y")

// __mod__
fn extends __mod__(self: Vec2, other: Vec2) -> Vec2 {
    return Vec2 { x: self.x % other.x, y: self.y % other.y }
}

let g = Vec2(7, 10) % Vec2(3, 4)
assert(g.x == 1, "overloaded % x")
assert(g.y == 2, "overloaded % y")

// __eq__
fn extends __eq__(self: Vec2, other: Vec2) -> Bool {
    return (self.x == other.x) && (self.y == other.y)
}
assert(Vec2(1, 2) == Vec2(1, 2), "overloaded ==")
assert(!(Vec2(1, 2) == Vec2(3, 4)), "overloaded == false")

// __ne__
fn extends __ne__(self: Vec2, other: Vec2) -> Bool {
    return (self.x != other.x) || (self.y != other.y)
}
assert(Vec2(1, 2) != Vec2(3, 4), "overloaded !=")
assert(!(Vec2(1, 2) != Vec2(1, 2)), "overloaded != false")

// __lt__
fn extends __lt__(self: Vec2, other: Vec2) -> Bool {
    return (self.x < other.x) && (self.y < other.y)
}
assert(Vec2(1, 2) < Vec2(3, 4), "overloaded <")

// __le__
fn extends __le__(self: Vec2, other: Vec2) -> Bool {
    return (self.x <= other.x) && (self.y <= other.y)
}
assert(Vec2(1, 2) <= Vec2(1, 2), "overloaded <=")

// __gt__
fn extends __gt__(self: Vec2, other: Vec2) -> Bool {
    return (self.x > other.x) && (self.y > other.y)
}
assert(Vec2(3, 4) > Vec2(1, 2), "overloaded >")

// __ge__
fn extends __ge__(self: Vec2, other: Vec2) -> Bool {
    return (self.x >= other.x) && (self.y >= other.y)
}
assert(Vec2(3, 4) >= Vec2(3, 4), "overloaded >=")

// __and__
fn extends __and__(self: Vec2, other: Vec2) -> Bool {
    return (self.x != 0) && (other.x != 0)
}
assert(Vec2(1, 2) && Vec2(3, 4), "overloaded &&")

// __or__
fn extends __or__(self: Vec2, other: Vec2) -> Bool {
    return (self.x != 0) || (other.x != 0)
}
assert(Vec2(0, 0) || Vec2(1, 0), "overloaded ||")

// Chaining operators
let result = Vec2(1, 1) + Vec2(2, 2) + Vec2(3, 3)
assert(result.x == 6, "chained + x")
assert(result.y == 6, "chained + y")

// toString with .toString() method (Cast::string doesn't call custom toString)
assert(Vec2(1, 2).toString() == "(1, 2)", "toString via method")

println("PASS: test_operator_overloading")
