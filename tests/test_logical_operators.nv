// ============================================================
// test_logical_operators.nv — Tests for && and || in all contexts
// ============================================================
// Verifies that logical AND (&&) and OR (||) work correctly in:
//   - if conditions
//   - elif conditions
//   - while loop conditions
//   - nested expressions
//   - short-circuit-style patterns

module test_logical_operators

// ── Basic && and || in if ─────────────────────────────────────────────────

if true && true {
    assert(true, "&& in if: true && true")
}

if true || false {
    assert(true, "|| in if: true || false")
}

if false || true {
    assert(true, "|| in if: false || true")
}

// ── && and || in elif ─────────────────────────────────────────────────────

let x = 5
if x > 10 {
    assert(false, "should not reach")
} elif x > 3 && x < 8 {
    assert(true, "&& in elif: compound range check")
}

let y = 1
if y == 0 {
    assert(false, "should not reach")
} elif y == 1 || y == 2 {
    assert(true, "|| in elif: multi-value check")
}

// ── && in while loop conditions ──────────────────────────────────────────

let i = 0
let sum = 0
while i < 10 && sum < 20 {
    sum = sum + i
    i = i + 1
}
// sum goes: 0,1,3,6,10,15,21 — stops when sum >= 20 at sum=21, i=7
assert(sum == 21, "while &&: sum == 21, got " + Cast::string(sum))
assert(i == 7, "while &&: i == 7, got " + Cast::string(i))

// ── || in while loop conditions ──────────────────────────────────────────

let a = 0
let b = 0
// This loop runs while either condition is true
while a < 3 || b < 2 {
    if a < 3 {
        a = a + 1
    }
    b = b + 1
}
// Both conditions must be false to stop
assert(a == 3, "while ||: a == 3, got " + Cast::string(a))
assert(b == 3, "while ||: b == 3, got " + Cast::string(b))

// ── Nested && and || ─────────────────────────────────────────────────────

let v = 5
if (v > 0 && v < 10) || v == 100 {
    assert(true, "nested (&&) || in if")
}

// ── Multiple && chained ──────────────────────────────────────────────────

let p = 5
let q = 10
let r = 15
if p < q && q < r && r < 20 {
    assert(true, "chained &&: p < q < r < 20")
}

// ── Multiple || chained ──────────────────────────────────────────────────

let color = "blue"
if color == "red" || color == "green" || color == "blue" {
    assert(true, "chained ||: color match")
}

// ── && in while with mutation ────────────────────────────────────────────

let count = 0
let running = true
while running && count < 5 {
    count = count + 1
    if count == 5 {
        running = false
    }
}
assert(count == 5, "while && with bool flag: count == 5")

// ── Comparison operators with && ─────────────────────────────────────────

let lo = 1
let hi = 10
let val = 5
assert(val >= lo && val <= hi, "&& range: val in [lo, hi]")
assert(!(val < lo && val > hi), "&& impossible range is false")

// ── With negation ────────────────────────────────────────────────────────

let done = false
let err = false
if !done && !err {
    assert(true, "&& with negation: !done && !err")
}

// ── elif chain with mixed operators ──────────────────────────────────────

let score = 75
let grade = ""
if score >= 90 && score <= 100 {
    grade = "A"
} elif score >= 80 && score < 90 {
    grade = "B"
} elif score >= 70 && score < 80 {
    grade = "C"
} elif score >= 60 && score < 70 {
    grade = "D"
} else {
    grade = "F"
}
assert(grade == "C", "elif && chain: grade == C, got " + grade)

// ── While with || and break-like pattern ─────────────────────────────────

let attempts = 0
let success = false
while !success || attempts < 1 {
    attempts = attempts + 1
    if attempts == 3 {
        success = true
    }
    // Safety: break after enough iterations
    if attempts > 10 {
        success = true
    }
}
assert(attempts == 3, "while || with flag: attempts == 3, got " + Cast::string(attempts))

println("PASS: All logical operator tests passed!")
