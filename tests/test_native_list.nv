module test_native_list

// Tests for native List:: functions (new: insert, swap, clear, set)

// --- List::push (existing) ---
let xs = [1, 2, 3]
xs.push(4)
assert(xs == [1, 2, 3, 4], "push appends")
assert(xs.len() == 4, "push increases length")

// --- List::pop (existing) ---
let ys = [10, 20, 30]
let popped = ys.pop()
assert(popped == 30, "pop returns last")
assert(ys == [10, 20], "pop shrinks list")

// --- List::remove (existing) ---
let zs = [1, 2, 3, 4, 5]
zs.remove(2)
assert(zs == [1, 2, 4, 5], "remove at index 2")
assert(zs.len() == 4, "remove shrinks list")

// --- List::len (existing) ---
assert([]: Int.len() == 0, "len empty list")
assert([1].len() == 1, "len single element")
assert([1, 2, 3, 4, 5].len() == 5, "len five elements")

// --- List::insert ---
let ins = [1, 2, 3]
ins.insert(1, 99)
assert(ins == [1, 99, 2, 3], "insert at index 1")
assert(ins.len() == 4, "insert increases length")

let ins2 = [1, 2, 3]
ins2.insert(0, 0)
assert(ins2 == [0, 1, 2, 3], "insert at index 0")

let ins3 = [1, 2, 3]
ins3.insert(3, 4)
assert(ins3 == [1, 2, 3, 4], "insert at end")

// --- List::swap ---
let sw = [10, 20, 30, 40]
sw.swap(0, 3)
assert(sw == [40, 20, 30, 10], "swap first and last")

let sw2 = [1, 2, 3]
sw2.swap(0, 1)
assert(sw2 == [2, 1, 3], "swap adjacent")

// --- List::clear ---
let cl = [1, 2, 3, 4, 5]
cl.clear()
assert(cl == []: Int, "clear empties list")
assert(cl.len() == 0, "clear sets length to 0")

let cl2 = []: String
cl2.clear()
assert(cl2.len() == 0, "clear already empty")

// --- List::set ---
let st = [10, 20, 30]
st.set(1, 99)
assert(st == [10, 99, 30], "set middle element")

let st2 = [1, 2, 3]
st2.set(0, 100)
assert(st2 == [100, 2, 3], "set first element")

let st3 = [1, 2, 3]
st3.set(2, 300)
assert(st3 == [1, 2, 300], "set last element")

// --- List operations with different types ---
let strs = ["hello", "world"]
strs.push("nova")
assert(strs.len() == 3, "push string list")
assert(strs[2] == "nova", "access pushed string")

let bools = [true, false, true]
bools.set(1, true)
assert(bools == [true, true, true], "set bools")

println("PASS: test_native_list")
