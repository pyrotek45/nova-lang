module test_std_color

import super.std.color

// --- Core colors ---
assert(color::white() == (255, 255, 255), "white")
assert(color::black() == (0, 0, 0), "black")
assert(color::red() == (230, 41, 55), "red")
assert(color::green() == (0, 228, 48), "green")
assert(color::blue() == (0, 121, 241), "blue")

// --- Palette colors ---
assert(color::lightGray() == (200, 200, 200), "lightGray")
assert(color::gold() == (255, 203, 0), "gold")

// --- rgb helper ---
let c = color::rgb(100, 150, 200)
assert(c == (100, 150, 200), "rgb helper")

// --- invert ---
let inv = color::invert(color::white())
assert(inv == (0, 0, 0), "invert white = black")

let inv2 = color::invert(color::black())
assert(inv2 == (255, 255, 255), "invert black = white")

// --- lerpColor ---
let mid = color::lerpColor(color::black(), color::white(), 0.5)
assert(mid[0] >= 126 && mid[0] <= 128, "lerp midpoint r")
assert(mid[1] >= 126 && mid[1] <= 128, "lerp midpoint g")
assert(mid[2] >= 126 && mid[2] <= 128, "lerp midpoint b")

// --- darken/lighten ---
let dark = color::darken(color::white(), 1.0)
assert(dark == (0, 0, 0), "darken white fully = black")

let light = color::lighten(color::black(), 1.0)
assert(light == (255, 255, 255), "lighten black fully = white")

println("PASS: test_std_color")
