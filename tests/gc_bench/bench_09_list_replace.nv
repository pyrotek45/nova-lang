module bench_09_list_replace
// Benchmark 9: In-place mutation (PINDEX) with ref-count management
// Replaces elements in a large list repeatedly.
// Tests that old values are properly dec'd and new values inc'd.

let data = []: Int
for i in 0..10000 {
    data.push(0)
}

for round in 0..100 {
    for i in 0..data.len() {
        data[i] = round * i
    }
}
