module test_module_access

import super.std.math
import super.std.io

// ===== TEST: Can we call functions using module::func syntax? =====

// Test if standalone functions from modules can be called with module:: prefix
// math module has: bin(), hex(), divmod(), toRadians(), toDegrees(), lerp(), etc.

// Try calling without module prefix (should work since import flattens into scope)
let b = bin(10)
println("TEST A1 - bin(10) no prefix: " + b)

let h = hex(255)
println("TEST A2 - hex(255) no prefix: " + h)

let lr = lerp(0.0, 10.0, 0.5)
println("TEST A3 - lerp no prefix: " + Cast::string(lr))

// io module has: prompt(), readLines(), etc.
// These need I/O so just test they're callable
println("TEST A4 - io functions imported: OK")

// Test: Extension methods are called with dot notation, not module:: prefix
let v = 5
let result = v.min(3)
println("TEST A5 - extension via dot: " + Cast::string(result))

// Test: fib is a standalone function from math
let f = fib(10)
println("TEST A6 - fib(10): " + Cast::string(f))

println("PASS: test_module_access")
