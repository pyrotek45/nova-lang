module test_blocks

import super.std.core

// ---- Block expression as value in let ----
fn add_in_block() -> Int {
    let a = { let x = 10; let y = 20; x + y }
    return a
}
assert(add_in_block() == 30, "block expression as value: 10+20=30")

// ---- Nested block expressions ----
fn nested_block() -> Int {
    let a = { let x = 5; x * 2 }
    let b = { let y = a + 1; y * 3 }
    return b
}
assert(nested_block() == 33, "nested blocks: (5*2+1)*3=33")

// ---- Block in if-branch ----
fn block_in_if(n: Int) -> Int {
    if n > 0 {
        let doubled = { let v = n; v * 2 }
        return doubled
    } else {
        let tripled = { let v = -n; v * 3 }
        return tripled
    }
    return 0
}
assert(block_in_if(5) == 10, "block in if branch: 5*2=10")
assert(block_in_if(-4) == 12, "block in else branch: 4*3=12")

// ---- Block with multiple statements ----
fn block_multi_stmt() -> Int {
    let result = {
        let a = 1
        let b = 2
        let c = 3
        let d = 4
        a + b + c + d
    }
    return result
}
assert(block_multi_stmt() == 10, "block multi-stmt: 1+2+3+4=10")

// ---- Block expression used in arithmetic ----
fn block_in_arith() -> Int {
    let base = 100
    let adj = { let x = 7; x * 3 }
    return base - adj
}
assert(block_in_arith() == 79, "block in arithmetic: 100-21=79")

// ---- StoreExpr (~>) basic usage ----
fn storeexpr_basic() -> Int {
    let out = 10 ~> v {
        v * v
    }
    return out
}
assert(storeexpr_basic() == 100, "storeexpr 10*10=100")

// ---- StoreExpr with a computed value ----
fn storeexpr_computed() -> Int {
    let base = 6
    let out = (base * 7) ~> product {
        product + 2
    }
    return out
}
assert(storeexpr_computed() == 44, "storeexpr (6*7)+2=44")

// ---- StoreExpr chain ----
fn storeexpr_chain() -> Int {
    let r1 = 3 ~> a {
        a * a
    }
    let r2 = r1 ~> b {
        b + 7
    }
    return r2
}
assert(storeexpr_chain() == 16, "storeexpr chain: 3*3+7=16")

// ---- StoreExpr used in function body ----
fn make_label(n: Int) -> String {
    let s = n ~> val {
        "value=" + Cast::string(val)
    }
    return s
}
assert(make_label(42) == "value=42", "storeexpr string result")

// ---- Block scope isolation ----
// Inner block variable does not leak out
fn block_isolation() -> Int {
    let outer_val = 5
    {
        let inner = 99
        outer_val = outer_val + 1
    }
    // inner should not be accessible here (just verify outer_val is correct)
    return outer_val
}
assert(block_isolation() == 6, "block isolation: outer_val updated once")

// ---- Block returning complex type ----
fn block_returns_string() -> String {
    let msg = {
        let prefix = "hello"
        let suffix = "world"
        prefix + " " + suffix
    }
    return msg
}
assert(block_returns_string() == "hello world", "block returns string")

// ---- Blocks in while loop body ----
fn blocks_in_while() -> Int {
    let sum = 0
    let i = 0
    while i < 5 {
        let inc = { let step = 2; step }
        sum += inc
        i += 1
    }
    return sum
}
assert(blocks_in_while() == 10, "blocks in while: 5*2=10")

// ---- Blocks in for-in body ----
fn blocks_in_for_in() -> Int {
    let total = 0
    for item in [1, 2, 3, 4, 5] {
        let contribution = { let v = item; v * v }
        total += contribution
    }
    return total
}
assert(blocks_in_for_in() == 55, "blocks in for-in: sum of squares 1..5=55")

println("PASS: test_blocks")
